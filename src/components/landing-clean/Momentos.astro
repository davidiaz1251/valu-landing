---
const categories = [
  {
    title: 'Bodas',
    description: 'Invitaciones, toppers y detalles que hacen mágico tu gran día',
    icon: '♡',
    image: '/media/images_public_69c11d14bba13990f133d6d0_296b37a14_generated_5a63a946.png',
    color: 'var(--lk-secondary)'
  },
  {
    title: 'Cumpleaños',
    description: 'Decoraciones únicas para celebrar cada año de vida',
    icon: '✦',
    image: '/media/images_public_69c11d14bba13990f133d6d0_e09c2d23f_generated_2175fea1.png',
    color: 'var(--lk-mint)'
  },
  {
    title: 'Baby Showers',
    description: 'Detalles tiernos para dar la bienvenida al bebé',
    icon: '◌',
    image: '/media/images_public_69c11d14bba13990f133d6d0_de5f491dc_generated_d6523004.png',
    color: 'hsla(42,65%,65%,.22)'
  },
  {
    title: 'Eventos Especiales',
    description: 'Graduaciones, aniversarios y todo lo que merece ser celebrado',
    icon: '★',
    image: '/media/images_public_69c11d14bba13990f133d6d0_4ed3bd86b_generated_6d0099b4.png',
    color: 'hsla(350,40%,90%,.7)'
  }
];
---

<section id="momentos" class="lk-momentos">
  <div class="lk-momentos__topfade" aria-hidden="true"></div>

  <div class="lk-momentos__container">
    <header class="lk-momentos__head" data-reveal>
      <span>Lo que hacemos</span>
      <h2>Momentos que creamos</h2>
      <p>Cada celebración merece algo hecho con el corazón</p>
    </header>

    <div class="lk-momentos__grid">
      {categories.map((item, i) => (
        <article class="lk-m-card" data-reveal style={`--delay:${i * 0.15}s;`}>
          <div class="lk-m-card__bg" style={`background:${item.color};`}></div>
          <img src={item.image} alt={item.title} />
          <div class="lk-m-card__overlay"></div>

          <div class="lk-m-card__content">
            <div class="lk-m-card__icon">{item.icon}</div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>

          <div class="lk-m-card__tape"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  const revealEls = document.querySelectorAll('#momentos [data-reveal]');

  if ('IntersectionObserver' in window && revealEls.length) {
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      });
    }, { threshold: 0.16, rootMargin: '0px 0px -50px 0px' });

    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }
</script>

<style>
  :root {
    --lk-secondary: hsla(350,40%,90%,.95);
    --lk-mint: hsla(160,30%,85%,.75);
  }

  .lk-momentos { padding: 96px 0 128px; position: relative; }
  .lk-momentos__topfade { position: absolute; inset: 0 0 auto 0; height: 96px; background: linear-gradient(to bottom, rgba(252,249,246,.95), transparent); pointer-events: none; }
  .lk-momentos__container { max-width: 1280px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }

  .lk-momentos__head { text-align: center; margin-bottom: 56px; opacity: 0; transform: translateY(20px); }
  .lk-momentos__head.is-visible { animation: lkMomentHeadIn .6s ease-out forwards; }
  .lk-momentos__head span { color: hsl(42 65% 65%); text-transform: uppercase; letter-spacing: .2em; font-size: .95rem; font-weight: 600; }
  .lk-momentos__head h2 { margin: 12px 0 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.9rem, 5vw, 3rem); color: #2f1f28; }
  .lk-momentos__head p { margin: 14px auto 0; color: #726069; font-size: clamp(1rem, 1.6vw, 1.12rem); max-width: 560px; }

  .lk-momentos__grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 16px; }

  .lk-m-card { position: relative; border-radius: 18px; overflow: hidden; aspect-ratio: 3 / 4; cursor: pointer; opacity: 0; transform: translateY(40px); }
  .lk-m-card.is-visible { animation: lkMomentCardIn .6s ease-out var(--delay, 0s) forwards; }

  .lk-m-card__bg { position: absolute; inset: 0; opacity: .6; }
  .lk-m-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; }
  .lk-m-card:hover img { transform: scale(1.05); }

  .lk-m-card__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(20,15,18,.7), rgba(20,15,18,.2) 45%, transparent); }
  .lk-m-card__content { position: absolute; left: 0; right: 0; bottom: 0; padding: 20px; color: #fff; z-index: 2; }
  .lk-m-card__icon { width: 32px; height: 32px; border-radius: 999px; display: grid; place-items: center; background: rgba(255,255,255,.2); backdrop-filter: blur(8px); margin-bottom: 10px; font-size: .95rem; }
  .lk-m-card h3 { margin: 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.2rem, 2.2vw, 1.5rem); line-height: 1.15; }
  .lk-m-card p { margin: 6px 0 0; color: rgba(255,255,255,.82); font-size: .88rem; line-height: 1.5; max-width: 270px; }

  .lk-m-card__tape { position: absolute; top: 16px; right: 16px; width: 48px; height: 18px; border-radius: 3px; transform: rotate(12deg); background: hsla(42,65%,65%,.6); opacity: 0; transition: opacity .3s ease; }
  .lk-m-card:hover .lk-m-card__tape { opacity: 1; }

  @media (min-width: 768px) {
    .lk-momentos { padding: 128px 0; }
    .lk-momentos__head { margin-bottom: 80px; }
    .lk-momentos__grid { gap: 24px; }
    .lk-m-card__content { padding: 24px; }
    .lk-m-card p { font-size: .92rem; }
  }

  @media (min-width: 1024px) {
    .lk-momentos__grid { grid-template-columns: repeat(4, minmax(0,1fr)); }
  }

  @keyframes lkMomentHeadIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes lkMomentCardIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lk-momentos__head,
    .lk-m-card { opacity: 1; transform: none; animation: none !important; }
    .lk-m-card img,
    .lk-m-card__tape { transition: none; }
  }
</style>

---
const steps = [
  {
    num: '01',
    title: 'Diseño',
    description: 'Creamos un diseño personalizado basado en tu visión y estilo',
    icon: '✎',
    image: '/media/images_public_69c11d14bba13990f133d6d0_d18e9f2af_generated_ae86e30b.png'
  },
  {
    num: '02',
    title: 'Corte',
    description: 'Utilizamos tecnología de precisión para cortes perfectos en cada detalle',
    icon: '✂',
    image: '/media/images_public_69c11d14bba13990f133d6d0_cd65a895f_generated_cc7704cd.png'
  },
  {
    num: '03',
    title: 'Ensamblaje',
    description: 'Cada capa se une a mano con cuidado y materiales premium',
    icon: '✋',
    image: '/media/images_public_69c11d14bba13990f133d6d0_b23bafa5f_generated_4b856256.png'
  },
  {
    num: '04',
    title: 'Entrega',
    description: 'Tu creación llega lista para brillar en tu momento especial',
    icon: '🎁',
    image: '/media/images_public_69c11d14bba13990f133d6d0_5b93f955f_generated_49441a7f.png'
  }
];
---

<section id="proceso" class="lk-proceso">
  <div class="lk-proceso__container">
    <header class="lk-proceso__head">
      <span>Nuestro proceso</span>
      <h2>Hecho a mano con detalle</h2>
      <p>Del concepto a la realidad, cada paso importa</p>
    </header>

    <div class="lk-proceso__grid">
      {steps.map((step, index) => (
        <article class="lk-p-wrap group">
          {index < steps.length - 1 && <i class="lk-p-card__connector" aria-hidden="true"></i>}

          <div class={`lk-p-card ${index % 2 ? 'is-offset' : ''}`}>
            <div class="lk-p-card__media">
              <img src={step.image} alt={step.title} />
              <div class="lk-p-card__fade"></div>
              <span class="lk-p-card__num">{step.num}</span>
            </div>

            <div class="lk-p-card__body">
              <div class="lk-p-card__icon">{step.icon}</div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .lk-proceso { padding: 96px 0 128px; background: rgba(245,240,236,.55); position: relative; overflow: hidden; }
  .lk-proceso::before { content: ''; position: absolute; top: 80px; right: 40px; width: 160px; height: 160px; border-radius: 50%; background: hsla(42,65%,65%,.12); filter: blur(28px); }
  .lk-proceso::after { content: ''; position: absolute; bottom: 70px; left: 20px; width: 240px; height: 240px; border-radius: 50%; background: hsla(350,40%,90%,.6); filter: blur(40px); }

  .lk-proceso__container { position: relative; z-index: 1; max-width: 1280px; margin: 0 auto; padding: 0 20px; }
  .lk-proceso__head { text-align: center; margin-bottom: 56px; }
  .lk-proceso__head span { color: hsl(42 65% 55%); text-transform: uppercase; letter-spacing: .14em; font-size: .78rem; font-weight: 700; }
  .lk-proceso__head h2 { margin: 12px 0 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4.4vw, 3.2rem); color: #2f1f28; }
  .lk-proceso__head p { margin: 14px 0 0; color: #726069; font-size: 1.03rem; }

  .lk-proceso__grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 20px; }
  .lk-p-wrap { position: relative; }

  .lk-p-card {
    background: rgba(255,255,255,.9);
    border: 1px solid rgba(228,218,213,.65);
    border-radius: 16px;
    overflow: hidden;
    transition: all .5s ease;
  }
  .group:hover .lk-p-card { border-color: hsla(42,65%,65%,.35); box-shadow: 0 18px 38px rgba(109,84,98,.09); }

  .lk-p-card__media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; }
  .lk-p-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; }
  .group:hover .lk-p-card__media img { transform: scale(1.05); }

  .lk-p-card__fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(252,249,246,.9) 0%, rgba(252,249,246,.45) 26%, rgba(252,249,246,0) 62%);
  }

  .lk-p-card__num { position: absolute; top: 16px; left: 16px; font-family: 'Playfair Display', Georgia, serif; font-size: 2.25rem; font-weight: 700; line-height: 1; color: rgba(255,255,255,.3); }

  .lk-p-card__body { margin-top: -30px; position: relative; padding: 20px 20px 22px; }
  .lk-p-card__icon { width: 44px; height: 44px; border-radius: 12px; background: hsla(160,30%,45%,.1); border: 1px solid hsla(160,30%,45%,.14); display: grid; place-items: center; font-size: 1.1rem; margin-bottom: 10px; }
  .lk-p-card h3 { margin: 0; font-family: 'Playfair Display', Georgia, serif; color: #2f1f28; font-size: 1.25rem; }
  .lk-p-card p { margin: 8px 0 0; color: #6f5b65; font-size: .9rem; line-height: 1.55; }

  .lk-p-card__connector { display: none; }

  @media (min-width: 1024px) {
    .lk-proceso__head { margin-bottom: 80px; }
    .lk-proceso__grid { grid-template-columns: repeat(4, minmax(0,1fr)); gap: 24px; }
    .lk-p-card.is-offset { margin-top: 48px; }
    .lk-p-card__connector {
      display: block;
      position: absolute;
      top: 50%;
      right: -12px;
      width: 24px;
      border-top: 2px dashed rgba(196,177,167,.8);
      z-index: 2;
    }
  }
</style>

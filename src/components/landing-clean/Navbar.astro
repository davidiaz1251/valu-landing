---
import { Menu } from '@lucide/astro';
const navLinks = [
  { label: 'Momentos', href: '#momentos' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Productos', href: '#productos' },
  { label: 'Personaliza', href: '#personaliza' },
  { label: 'Testimonios', href: '#testimonios' }
];
---

<nav class="lk-nav" id="lkNav">
  <div class="lk-nav__container">
    <div class="lk-nav__row">
      <a href="#" class="lk-brand" aria-label="Inicio Valu">
        <img src="/images/logo-valu-round.jpg" alt="Logo Valu" class="lk-brand__logo" />
      </a>

      <div class="lk-nav__links">
        {navLinks.map((link) => (
          <a href={`/${link.href}`} class="lk-nav__link">
            {link.label}
            <span class="lk-nav__line"></span>
          </a>
        ))}
      </div>

      <div class="lk-nav__actions">
        <div class="lk-nav__auth-item nav__auth-item">
          <img id="authAvatar" class="lk-nav__avatar" alt="Perfil" hidden />
          <a href="/login" class="lk-nav__login" id="authMenuLink" data-auth-menu>Iniciar sesión</a>
        </div>
        <a href="#personaliza" class="lk-nav__cta">Haz tu pedido</a>
      </div>

      <button class="lk-nav__menu" id="lkNavMenuBtn" aria-label="Abrir menú" aria-expanded="false"><Menu size={20} /></button>
    </div>
  </div>

  <div class="lk-mobile" id="lkMobileMenu">
    <div class="lk-mobile__inner">
      {navLinks.map((link) => (
        <a href={`/${link.href}`} class="lk-mobile__link">{link.label}</a>
      ))}
      <div class="lk-mobile__auth nav__auth-item">
        <img id="authAvatarMobile" class="lk-mobile__avatar" alt="Perfil" hidden />
        <a href="/login" class="lk-mobile__login" id="authMenuLinkMobile" data-auth-menu-mobile>Iniciar sesión</a>
      </div>
      <a href="#personaliza" class="lk-mobile__cta">Haz tu pedido</a>
    </div>
  </div>
</nav>

<script is:inline>
  const nav = document.getElementById('lkNav');
  const btn = document.getElementById('lkNavMenuBtn');
  const mobile = document.getElementById('lkMobileMenu');

  const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 40);
  onScroll();
  window.addEventListener('scroll', onScroll);

  const closeMobile = () => {
    if (!mobile) return;
    mobile.classList.remove('is-open');
    btn?.setAttribute('aria-expanded', 'false');
  };

  const openMobile = () => {
    if (!mobile) return;
    mobile.classList.add('is-open');
    btn?.setAttribute('aria-expanded', 'true');
  };

  btn?.addEventListener('click', () => {
    if (!mobile) return;
    const open = mobile.classList.contains('is-open');
    if (open) closeMobile();
    else openMobile();
  });

  mobile?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', closeMobile);
  });
</script>

<style>
  .lk-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    background: transparent;
    transition: all .5s ease;
    transform: translateY(-100px);
    animation: lkNavIn .6s ease-out forwards;
  }
  .lk-nav.is-scrolled { background: rgba(252,249,246,.8); backdrop-filter: blur(18px); border-bottom: 1px solid rgba(228,218,213,.6); box-shadow: 0 2px 12px rgba(0,0,0,.04); }

  .lk-nav__container { max-width: 1280px; margin: 0 auto; padding: 0 20px; }

  @media (min-width: 768px) {
    .lk-nav__container { padding: 0 32px; }
  }

    .lk-nav__row { height: 64px; display: flex; align-items: center; justify-content: space-between; gap: 14px; }

  .lk-brand { display: inline-flex; align-items: center; text-decoration: none; }
  .lk-brand__logo { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(228,218,213,.9); box-shadow: 0 6px 16px rgba(0,0,0,.08); }

  .lk-nav__links { display: none; align-items: center; gap: 32px; }
  .lk-nav__link { position: relative; text-decoration: none; color: hsl(340 10% 45%); font-size: .875rem; font-weight: 500; font-family: 'DM Sans', system-ui, sans-serif; }
  .lk-nav__line { position: absolute; left: 0; bottom: -4px; width: 0; height: 2px; border-radius: 999px; background: hsl(42 65% 65%); transition: width .25s ease; }
  .lk-nav__link:hover { color: hsl(340 20% 15%); }
  .lk-nav__link:hover .lk-nav__line { width: 100%; }

  .lk-nav__actions { display: none; align-items: center; gap: 10px; }
  .lk-nav__auth-item { position: relative; display: inline-flex; align-items: center; gap: 8px; }
  .lk-nav__avatar { width: 28px; height: 28px; border-radius: 999px; object-fit: cover; border: 1px solid rgba(228,218,213,.9); }
  .lk-nav__avatar[hidden] { display:none !important; }
  :global(.nav__auth-dropdown) { position: absolute; top: calc(100% + 8px); right: 0; min-width: 180px; background: #fff; border: 1px solid rgba(228,218,213,.9); border-radius: 12px; box-shadow: 0 12px 26px rgba(0,0,0,.08); padding: 8px; display: none; gap: 4px; z-index: 70; }\n  :global(.nav__auth-dropdown.is-open) { display: grid; }
  :global(.nav__auth-dropdown-link) { display:block; width:100%; text-align:left; background: transparent; border: 0; text-decoration:none; color:#5f4a54; padding:8px 10px; border-radius:8px; font: inherit; cursor:pointer; }
  :global(.nav__auth-dropdown-link:hover) { background: rgba(232,218,213,.35); }
  .lk-nav__login { text-decoration: none; border-radius: 999px; border: 1px solid rgba(228,218,213,.9); padding: 10px 14px; font-size: .84rem; font-weight: 600; color: #5f4a54; background: rgba(255,255,255,.7); font-family: 'DM Sans', system-ui, sans-serif; }
  .lk-nav__cta { text-decoration: none; border-radius: 999px; background: hsl(160 30% 45%); color: #fff; padding: 10px 18px; font-size: .88rem; font-weight: 600; box-shadow: 0 10px 20px rgba(50,130,105,.15); font-family: 'DM Sans', system-ui, sans-serif; }

  .lk-nav__menu { border: 0; background: transparent; color: #2f1f28; font-size: 1.1rem; padding: 6px; }

  .lk-mobile {
    background: rgba(252,249,246,.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(228,218,213,.6);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition: max-height .3s ease, opacity .25s ease;
  }
  .lk-mobile.is-open {
    max-height: 520px;
    opacity: 1;
    pointer-events: auto;
  }
  .lk-mobile__inner { max-width: 1280px; margin: 0 auto; padding: 14px 20px 16px; display: grid; gap: 6px; }
  .lk-mobile__link { display: block; text-decoration: none; color: #6e5a64; font-size: 1rem; font-weight: 500; padding: 8px 0; }
  .lk-mobile__auth { display:inline-flex; align-items:center; gap:8px; margin-top: 6px; }
  .lk-mobile__avatar { width: 26px; height: 26px; border-radius: 999px; object-fit: cover; border: 1px solid rgba(228,218,213,.9); }
  .lk-mobile__avatar[hidden] { display:none !important; }
  .lk-mobile__login { text-decoration: none; width: max-content; border-radius: 999px; border: 1px solid rgba(228,218,213,.9); padding: 10px 14px; font-size: .84rem; font-weight: 600; color: #5f4a54; background: rgba(255,255,255,.7); }
  .lk-mobile__cta { margin-top: 4px; text-decoration: none; width: max-content; border-radius: 999px; background: hsl(160 30% 45%); color: #fff; padding: 10px 18px; font-size: .88rem; font-weight: 600; }

  @media (min-width: 768px) {
    .lk-nav__row { height: 80px; }
    .lk-nav__links { display: flex; }
    .lk-nav__actions { display: inline-flex; }
    .lk-nav__menu, .lk-mobile { display: none; }
    .lk-brand__logo { width: 52px; height: 52px; }
  }

  @keyframes lkNavIn {
    from { transform: translateY(-100px); }
    to { transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lk-nav { animation: none; transform: none; }
    .lk-mobile { transition: none; }
  }
</style>

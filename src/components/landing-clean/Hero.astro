---
const heroImg = '/media/images_public_69c11d14bba13990f133d6d0_a2d451895_generated_d22ed13b.png';
const dots = Array.from({ length: 6 }, (_, i) => ({
  top: 15 + i * 14,
  left: 10 + (i % 3) * 35,
  delay: i * 0.5
}));
---

<section class="lk-hero">
  <div class="lk-hero__bg">
    <div class="lk-blob lk-blob--1"></div>
    <div class="lk-blob lk-blob--2"></div>
    <div class="lk-blob lk-blob--3"></div>

    {dots.map((d) => (
      <span class="lk-dot" style={`top:${d.top}%;left:${d.left}%;animation-delay:${d.delay}s;`}></span>
    ))}
  </div>

  <div class="lk-hero__container">
    <div class="lk-hero__grid">
      <div class="lk-hero__content">
        <div class="lk-pill">✦ <span>Hecho a mano con amor</span></div>

        <h1>
          Creamos <span class="lk-underline">momentos
            <svg class="lk-underline-svg" viewBox="0 0 200 12" fill="none" aria-hidden="true">
              <path d="M2 8C40 2 100 2 198 8" />
            </svg>
          </span><br />
          que se <em>sienten</em>
        </h1>

        <p>
          Cada pieza es única, personalizada y creada a mano con materiales premium.
          Desde invitaciones hasta toppers — hacemos que tus ideas cobren vida.
        </p>

        <div class="lk-hero__actions">
          <a href="#personaliza" class="lk-btn lk-btn--primary">Diseña el tuyo →</a>
          <a href="#productos" class="lk-btn lk-btn--ghost">Ver catálogo</a>
        </div>

        <div class="lk-trust">
          <span><i class="is-primary"></i> +500 pedidos</span>
          <span><i class="is-accent"></i> 100% personalizado</span>
        </div>
      </div>

      <div class="lk-hero__media">
        <div class="lk-paper lk-paper--a"></div>
        <div class="lk-paper lk-paper--b"></div>

        <div class="lk-hero__imageWrap">
          <img src={heroImg} alt="Cake topper artesanal de Valu Kraft con detalles en oro" />
          <div class="lk-hero__overlay"></div>
        </div>

        <div class="lk-badge">
          <span class="lk-badge__icon">✦</span>
          <div>
            <small>Calidad</small>
            <strong>Premium</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lk-hero { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; padding-top: 80px; }
  .lk-hero__bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  .lk-blob { position: absolute; border-radius: 999px; filter: blur(56px); }
  .lk-blob--1 { top: -80px; right: -80px; width: 384px; height: 384px; background: hsla(350,40%,90%,.4); animation: lkPaperIn .8s .2s ease-out both; }
  .lk-blob--2 { bottom: -128px; left: -80px; width: 320px; height: 320px; background: hsla(160,30%,85%,.3); animation: lkPaperIn .8s .4s ease-out both; }
  .lk-blob--3 { top: 33%; right: 25%; width: 256px; height: 256px; background: hsla(42,65%,65%,.15); animation: lkPaperIn .8s .6s ease-out both; }

  .lk-dot { position: absolute; width: 6px; height: 6px; border-radius: 999px; background: hsla(42,65%,65%,.6); animation: lkDot 3s infinite; }

  .lk-hero__container { position: relative; width: 100%; max-width: 1280px; margin: 0 auto; padding: 0 20px; }
  .lk-hero__grid { display: grid; gap: 48px; align-items: center; }

  .lk-pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 999px; background: hsla(350,40%,90%,.6); border: 1px solid hsla(350,40%,85%,.8); margin-bottom: 24px; animation: lkFadeUp .6s .2s ease-out both; }
  .lk-pill span { color: #5f4a54; font-size: .72rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }

  .lk-hero h1 { margin: 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2.25rem, 7vw, 4.5rem); line-height: 1.05; font-weight: 600; color: #2f1f28; animation: lkFadeUp .7s .3s ease-out both; }
  .lk-hero h1 em { color: hsl(160 30% 45%); font-style: normal; }
  .lk-underline { position: relative; display: inline-block; }
  .lk-underline .lk-underline-svg { position: absolute; left: 0; bottom: -8px; width: 100%; height: auto; overflow: visible; }
  .lk-underline .lk-underline-svg path { stroke: hsl(42 65% 65%); stroke-width: 3; stroke-linecap: round; fill: none; }

  .lk-hero p { margin: 24px 0 0; max-width: 540px; color: #6b5963; font-size: clamp(1.02rem, 1.6vw, 1.22rem); line-height: 1.65; animation: lkFadeUp .6s .5s ease-out both; }

  .lk-hero__actions { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 14px; animation: lkFadeUp .6s .7s ease-out both; }
  .lk-btn { display: inline-flex; align-items: center; justify-content: center; text-decoration: none; border-radius: 999px; padding: 14px 28px; font-weight: 600; font-size: 1rem; }
  .lk-btn--primary { background: hsl(160 30% 45%); color: #fff; box-shadow: 0 16px 36px rgba(50,130,105,.2); }
  .lk-btn--ghost { border: 2px solid rgba(220,206,198,.9); color: #3d2d37; }

  .lk-trust { margin-top: 40px; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; color: #7a6871; font-size: .92rem; animation: lkFadeIn .6s .9s ease-out both; }
  .lk-trust span { display: inline-flex; align-items: center; gap: 8px; }
  .lk-trust i { width: 8px; height: 8px; border-radius: 999px; display: inline-block; }
  .lk-trust i.is-primary { background: hsl(160 30% 45%); }
  .lk-trust i.is-accent { background: hsl(42 65% 65%); }

  .lk-hero__media { position: relative; animation: lkMediaIn .8s .4s ease-out both; }
  .lk-paper { position: absolute; inset: -16px; border-radius: 24px; }
  .lk-paper--a { background: hsla(350,40%,90%,.5); transform: rotate(3deg); }
  .lk-paper--b { background: hsla(160,30%,85%,.4); transform: rotate(-2deg); }

  .lk-hero__imageWrap { position: relative; border-radius: 18px; overflow: hidden; box-shadow: 0 24px 52px rgba(28,18,24,.12); }
  .lk-hero__imageWrap img { width: 100%; height: auto; display: block; object-fit: cover; }
  .lk-hero__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(252,249,246,.2), transparent 58%); }

  .lk-badge {
    position: absolute;
    left: -16px;
    bottom: -16px;
    border-radius: 16px;
    padding: 14px;
    background: rgba(255,255,255,.96);
    border: 1px solid rgba(228,218,213,.65);
    box-shadow: 0 16px 36px rgba(0,0,0,.1);
    display: flex;
    gap: 10px;
    align-items: center;
    animation: lkBadgeFloat 4s ease-in-out infinite;
    will-change: transform;
  }
  .lk-badge__icon { width: 40px; height: 40px; border-radius: 999px; background: hsla(42,65%,65%,.2); display: grid; place-items: center; color: hsl(42 65% 55%); }
  .lk-badge small { display: block; color: #8b7a82; font-size: .72rem; }
  .lk-badge strong { font-family: 'Playfair Display', Georgia, serif; color: #2f1f28; font-size: 1rem; }

  @media (min-width: 768px) {
    .lk-badge { left: -24px; bottom: -24px; }
  }

  @media (min-width: 1024px) {
    .lk-hero__grid { grid-template-columns: 1fr 1fr; gap: 64px; }
  }

  @keyframes lkFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes lkFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes lkMediaIn {
    from { opacity: 0; transform: scale(.9) rotate(2deg); }
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes lkPaperIn {
    from { opacity: 0; transform: translateY(30px) rotate(-2deg); }
    to { opacity: 1; transform: translateY(0) rotate(0deg); }
  }

  @keyframes lkBadgeFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes lkDot {
    0%,100% { opacity: 0; transform: scale(.5); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lk-badge,
    .lk-dot,
    .lk-blob,
    .lk-pill,
    .lk-hero h1,
    .lk-hero p,
    .lk-hero__actions,
    .lk-trust,
    .lk-hero__media { animation: none; }
  }

</style>

---
const testimonials = [
  {
    name: 'María García',
    event: 'Boda',
    text: 'Las invitaciones de mi boda fueron un sueño hecho realidad. Cada detalle era perfecto, mis invitados quedaron encantados con la calidad y el diseño. ¡Superaron todas mis expectativas!',
    rating: 5
  },
  {
    name: 'Carolina Mejía',
    event: 'Baby Shower',
    text: 'Los toppers y las decoraciones para el baby shower de mi hija fueron increíbles. Se nota que cada pieza se hace con amor y dedicación. No podría estar más feliz.',
    rating: 5
  },
  {
    name: 'Ana Lucía Torres',
    event: 'Cumpleaños',
    text: 'Pedí un topper personalizado para los 50 años de mi mamá y fue el centro de atención. La calidad del material y el acabado son impresionantes. ¡Ya soy clienta fija!',
    rating: 5
  }
];
---

<section id="testimonios" class="lk-testimonios">
  <div class="lk-testimonios__container">
    <header class="lk-testimonios__head">
      <span>Lo que dicen</span>
      <h2>Historias de nuestros clientes</h2>
    </header>

    <div class="lk-testimonios__grid">
      {testimonials.map((item, idx) => (
        <article class={`lk-t-card ${idx === 1 ? 'is-center' : ''}`}>
          <div class="lk-t-card__tape"></div>
          <div class="lk-t-card__quote">❝</div>

          <div class="lk-t-card__stars" aria-label={`${item.rating} estrellas`}>
            {Array.from({ length: item.rating }).map(() => <span>★</span>)}
          </div>

          <p class="lk-t-card__text">“{item.text}”</p>

          <footer class="lk-t-card__footer">
            <strong>{item.name}</strong>
            <small>{item.event}</small>
          </footer>

          <i class="lk-t-card__corner"></i>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .lk-testimonios { padding: 100px 0 120px; position: relative; overflow: hidden; }
  .lk-testimonios::before,
  .lk-testimonios::after {
    content: '';
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: hsla(42,65%,65%,.45);
    animation: lkSparkle 3s ease-in-out infinite;
  }
  .lk-testimonios::before { top: 24%; left: 8%; }
  .lk-testimonios::after { top: 64%; right: 12%; animation-delay: .9s; }

  .lk-testimonios__container { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
  .lk-testimonios__head { text-align: center; margin-bottom: 56px; }
  .lk-testimonios__head span { color: hsl(42 65% 55%); text-transform: uppercase; letter-spacing: .14em; font-size: .78rem; font-weight: 700; }
  .lk-testimonios__head h2 { margin: 12px 0 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4.4vw, 3.2rem); color: #2f1f28; }

  .lk-testimonios__grid { display: grid; grid-template-columns: 1fr; gap: 18px; }
  .lk-t-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(228,218,213,.65);
    border-radius: 18px;
    padding: 24px 20px 20px;
    box-shadow: 0 6px 16px rgba(0,0,0,.05);
    overflow: hidden;
  }
  .lk-t-card__tape {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 14px;
    border-radius: 0 0 4px 4px;
    background: hsla(42,65%,65%,.45);
  }
  .lk-t-card__quote { color: hsla(42,65%,55%,.38); font-size: 2rem; line-height: 1; }
  .lk-t-card__stars { margin-top: 10px; display: flex; gap: 3px; color: hsl(42 65% 55%); font-size: .95rem; }
  .lk-t-card__text { margin: 14px 0 0; color: #4e3d46; font-style: italic; line-height: 1.65; }
  .lk-t-card__footer { margin-top: 16px; padding-top: 12px; border-top: 1px solid rgba(228,218,213,.65); display: grid; gap: 3px; }
  .lk-t-card__footer strong { font-family: 'Playfair Display', Georgia, serif; color: #2f1f28; font-size: 1.02rem; }
  .lk-t-card__footer small { color: #7a6871; }
  .lk-t-card__corner { position: absolute; right: 0; bottom: 0; width: 28px; height: 28px; background: rgba(243,236,232,.8); border-radius: 14px 0 0 0; }

  @media (min-width: 1024px) {
    .lk-testimonios__grid { grid-template-columns: repeat(3, minmax(0,1fr)); gap: 22px; }
    .lk-t-card.is-center { margin-top: -16px; }
  }

  @keyframes lkSparkle {
    0%,100% { opacity: 0; transform: scale(.6); }
    50% { opacity: 1; transform: scale(1.4); }
  }
</style>

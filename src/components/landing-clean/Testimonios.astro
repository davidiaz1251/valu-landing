---
const testimonials = [
  {
    name: 'María García',
    event: 'Boda',
    text: 'Las invitaciones de mi boda fueron un sueño hecho realidad. Cada detalle era perfecto, mis invitados quedaron encantados con la calidad y el diseño. ¡Superaron todas mis expectativas!',
    rating: 5
  },
  {
    name: 'Carolina Mejía',
    event: 'Baby Shower',
    text: 'Los toppers y las decoraciones para el baby shower de mi hija fueron increíbles. Se nota que cada pieza se hace con amor y dedicación. No podría estar más feliz.',
    rating: 5
  },
  {
    name: 'Ana Lucía Torres',
    event: 'Cumpleaños',
    text: 'Pedí un topper personalizado para los 50 años de mi mamá y fue el centro de atención. La calidad del material y el acabado son impresionantes. ¡Ya soy clienta fija!',
    rating: 5
  }
];
---

<section id="testimonios" class="lk-testimonios">
  <div class="lk-testimonios__sparkles" aria-hidden="true">
    <span style="--top:20%;--left:5%;--delay:0s"></span>
    <span style="--top:40%;--left:30%;--delay:.8s"></span>
    <span style="--top:60%;--left:55%;--delay:1.6s"></span>
    <span style="--top:80%;--left:80%;--delay:2.4s"></span>
  </div>

  <div class="lk-testimonios__container">
    <header class="lk-testimonios__head" data-reveal>
      <span>Lo que dicen</span>
      <h2>Historias de nuestros clientes</h2>
    </header>

    <div class="lk-testimonios__grid">
      {testimonials.map((item, idx) => (
        <article class={`lk-t-card ${idx === 1 ? 'is-center' : idx === 0 ? 'is-rot-left' : 'is-rot-right'}`} data-reveal style={`--delay:${idx * 0.15}s;`}>
          <div class="lk-t-card__tape"></div>
          <div class="lk-t-card__quote">❝</div>

          <div class="lk-t-card__stars" aria-label={`${item.rating} estrellas`}>
            {Array.from({ length: item.rating }).map(() => <span>★</span>)}
          </div>

          <p class="lk-t-card__text">“{item.text}”</p>

          <footer class="lk-t-card__footer">
            <strong>{item.name}</strong>
            <small>{item.event}</small>
          </footer>

          <i class="lk-t-card__corner"></i>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const testimoniosRevealEls = document.querySelectorAll('#testimonios [data-reveal]');

    if ('IntersectionObserver' in window && testimoniosRevealEls.length) {
      const testimoniosIO = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -40px 0px' });

      testimoniosRevealEls.forEach((el) => testimoniosIO.observe(el));
    } else {
      testimoniosRevealEls.forEach((el) => el.classList.add('is-visible'));
    }
  })();
</script>

<style>
  .lk-testimonios { padding: 96px 0 128px; position: relative; overflow: hidden; }

  .lk-testimonios__sparkles { position: absolute; inset: 0; pointer-events: none; }
  .lk-testimonios__sparkles span {
    position: absolute;
    top: var(--top);
    left: var(--left);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: hsla(42,65%,65%,.4);
    animation: lkSparkle 3s infinite;
    animation-delay: var(--delay);
  }

  .lk-testimonios__container { max-width: 1280px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }

  .lk-testimonios__head { text-align: center; margin-bottom: 56px; opacity: 0; transform: translateY(20px); }
  .lk-testimonios__head.is-visible { animation: lkTestiHeadIn .6s ease-out forwards; }
  .lk-testimonios__head span { color: hsl(42 65% 65%); text-transform: uppercase; letter-spacing: .1em; font-size: .875rem; line-height: 1.25rem; font-weight: 500; }
  .lk-testimonios__head h2 { margin: 12px 0 0; font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 600; color: #2f1f28; }

  .lk-testimonios__grid { display: grid; grid-template-columns: 1fr; gap: 24px; }

  .lk-t-card {
    position: relative;
    background: hsl(30 30% 97%);
    border: 1px solid hsla(30,20%,88%,.55);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(47,31,40,.06);
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    transition: box-shadow .5s ease;
  }
  .lk-t-card.is-visible { animation: lkTestiCardIn .6s ease-out var(--delay, 0s) forwards; }
  .lk-t-card:hover { box-shadow: 0 16px 28px rgba(47,31,40,.09); }

  .lk-t-card__tape {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 16px;
    border-radius: 0 0 4px 4px;
    background: hsla(42,65%,65%,.4);
  }

  .lk-t-card__quote { color: hsla(42,65%,65%,.3); font-size: 2rem; line-height: 1; margin-bottom: 14px; }

  .lk-t-card__stars { margin-bottom: 14px; display: flex; gap: 4px; color: hsl(42 65% 65%); font-size: .95rem; }

  .lk-t-card__text { margin: 0; color: rgba(47,31,40,.8); line-height: 1.7; font-size: 1rem; font-style: italic; }

  .lk-t-card__footer { margin-top: 24px; padding-top: 16px; border-top: 1px solid hsla(30,20%,88%,.55); display: grid; gap: 2px; }
  .lk-t-card__footer strong { font-family: 'Playfair Display', Georgia, serif; color: #2f1f28; font-size: 1.1rem; font-weight: 600; }
  .lk-t-card__footer small { color: #7a6871; font-size: .875rem; }

  .lk-t-card__corner { position: absolute; right: 0; bottom: 0; width: 32px; height: 32px; background: rgba(245,240,236,.7); border-radius: 16px 0 0 0; }

  @media (min-width: 768px) {
    .lk-testimonios { padding: 128px 0; }
    .lk-testimonios__head { margin-bottom: 80px; }
  }

  @media (min-width: 1024px) {
    .lk-testimonios__grid { grid-template-columns: repeat(3, minmax(0,1fr)); gap: 32px; }
    .lk-t-card.is-center { margin-top: -16px; }
    .lk-t-card.is-rot-left { transform: translateY(30px) rotate(-1deg); }
    .lk-t-card.is-rot-right { transform: translateY(30px) rotate(1deg); }
    .lk-t-card.is-rot-left.is-visible { animation: lkTestiCardInLeft .6s ease-out var(--delay, 0s) forwards; }
    .lk-t-card.is-rot-right.is-visible { animation: lkTestiCardInRight .6s ease-out var(--delay, 0s) forwards; }
  }

  @keyframes lkSparkle {
    0%, 100% { opacity: 0; transform: scale(.5); }
    50% { opacity: 1; transform: scale(1.5); }
  }

  @keyframes lkTestiHeadIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes lkTestiCardIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes lkTestiCardInLeft {
    from { opacity: 0; transform: translateY(30px) rotate(0deg); }
    to { opacity: 1; transform: translateY(0) rotate(-1deg); }
  }

  @keyframes lkTestiCardInRight {
    from { opacity: 0; transform: translateY(30px) rotate(0deg); }
    to { opacity: 1; transform: translateY(0) rotate(1deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lk-testimonios__head,
    .lk-t-card { opacity: 1; transform: none !important; animation: none !important; }
    .lk-testimonios__sparkles span { animation: none; }
  }
</style>

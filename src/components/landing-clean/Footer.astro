---
import { AtSign, Globe, Music2 } from '@lucide/astro';
---

<footer class="lk-footer">
  <div class="lk-footer__container">
    <div class="lk-footer__grid">
      <div>
        <div class="lk-footer__brand">
          <span class="lk-footer__spark">✦</span>
          <span class="lk-footer__brandText">Valu Kraft</span>
        </div>
        <p class="lk-footer__desc">
          Creaciones artesanales personalizadas para tus momentos más especiales.
          Cada pieza hecha con amor y atención al detalle.
        </p>
      </div>

      <div>
        <h4>Explora</h4>
        <nav class="lk-footer__links">
          <a href="/#momentos">Momentos</a>
          <a href="/#proceso">Proceso</a>
          <a href="/#productos">Productos</a>
          <a href="/#personaliza">Personaliza</a>
          <a href="/#testimonios">Testimonios</a>
        </nav>
      </div>

      <div>
        <h4>Contacto</h4>
        <div class="lk-footer__contact">
          <div class="lk-footer__socials">
            <a href="https://instagram.com/valu_kraft" target="_blank" rel="noopener noreferrer" aria-label="Instagram Valu Kraft"><AtSign size={16} /><span>Instagram</span></a>
            <a href="https://www.facebook.com/share/1DrTnxMxss/" target="_blank" rel="noopener noreferrer" aria-label="Facebook Valu Kraft"><Globe size={16} /><span>Facebook</span></a>
            <a href="https://www.tiktok.com/@valu_kraft" target="_blank" rel="noopener noreferrer" aria-label="TikTok Valu Kraft"><Music2 size={16} /><span>TikTok</span></a>
          </div>
          <p>Email: hola@valukraft.com</p>
        </div>
      </div>
    </div>

    <div class="lk-footer__bottom">
      <p>© 2026 Valu Kraft. Todos los derechos reservados.</p>
      <p>Hecho con <span class="lk-footer__heart">♥</span> en cada detalle</p>
    </div>
  </div>
</footer>

<style>
  .lk-footer {
    border-top: 1px solid hsla(30,20%,88%,.5);
    background: hsla(30,30%,97%,.5);
  }

  .lk-footer__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 20px 64px;
  }

  .lk-footer__grid {
    display: grid;
    gap: 40px;
  }

  .lk-footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .lk-footer__spark { color: hsl(42 65% 65%); }

  .lk-footer__brandText {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: hsl(340 20% 15%);
  }

  .lk-footer__desc {
    margin: 0;
    max-width: 300px;
    font-size: .875rem;
    line-height: 1.7;
    color: hsl(340 10% 45%);
  }

  .lk-footer h4 {
    margin: 0 0 16px;
    font-size: 1rem;
    font-weight: 500;
    color: hsl(340 20% 15%);
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .lk-footer__links,
  .lk-footer__contact {
    display: grid;
    gap: 10px;
  }

  .lk-footer__socials { display: grid; gap: 10px; margin-bottom: 2px; }
  .lk-footer__socials a { text-decoration: none; color: hsl(340 10% 45%); display: inline-flex; align-items: center; gap: 8px; font-size: .875rem; font-family: 'DM Sans', system-ui, sans-serif; }
  .lk-footer__socials a:hover { color: hsl(340 20% 15%); }

  .lk-footer__links a,
  .lk-footer__contact p {
    margin: 0;
    text-decoration: none;
    font-size: .875rem;
    color: hsl(340 10% 45%);
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .lk-footer__links a:hover { color: hsl(340 20% 15%); }

  .lk-footer__bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid hsla(30,20%,88%,.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .lk-footer__bottom p {
    margin: 0;
    font-size: .75rem;
    color: hsl(340 10% 45%);
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .lk-footer__heart { color: hsl(340 20% 25%); }

  @media (min-width: 768px) {
    .lk-footer__container { padding: 64px 32px; }
    .lk-footer__grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
    .lk-footer__bottom { flex-direction: row; }
  }
</style>

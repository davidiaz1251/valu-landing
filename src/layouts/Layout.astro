---
import '../styles/global.css';
import Navbar from '../components/landing-clean/Navbar.astro';
import Footer from '../components/landing-clean/Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Valu Kraft - Papelería creativa y personalización artesanal. Transformamos tus ideas en productos únicos hechos con amor.",
  noindex = false
} = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? 'https://wshszoghxaserycscvka.supabase.co';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? 'sb_publishable_JbFfvEa-5l8QISrKp6NUGQ_nfa8OrfQ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL ?? 'https://www.valukraft.com').replace(/\/$/, '');
const canonical = `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}/images/logo-valu-round.jpg`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Valu Kraft',
  url: siteUrl,
  logo: ogImage,
  sameAs: [
    'https://instagram.com/valu_kraft',
    'https://www.facebook.com/share/1DrTnxMxss/',
    'https://www.tiktok.com/@valu_kraft'
  ]
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Valu Kraft',
  image: ogImage,
  url: siteUrl,
  telephone: '+34600000000',
  email: 'hola@valukraft.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Madrid',
    addressRegion: 'Comunidad de Madrid',
    addressCountry: 'ES'
  },
  areaServed: ['Madrid', 'España'],
  sameAs: orgSchema.sameAs
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="papelería creativa, personalización, artesanal, regalos personalizados, invitaciones, cake toppers, decoración eventos" />
    <meta name="author" content="Valu Kraft" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Valu Kraft" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Logo redondo de Valu Kraft" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=20260328b" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=20260328b" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=20260328b" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260328b" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
    <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
      window.__SUPABASE_URL = supabaseUrl || '';
      window.__SUPABASE_ANON_KEY = supabaseAnonKey || '';
    </script>
    <script type="text/javascript" charset="UTF-8" src="//cdn.cookie-script.com/s/406a37b1ea358f7ea88617ea8bc8c4cd.js"></script>
    <script is:inline>
      if (window.location.hash.includes('access_token=') && !window.location.pathname.startsWith('/auth/callback')) {
        const next = encodeURIComponent('/plantillas');
        window.location.replace('/auth/callback?next=' + next + window.location.hash);
      }
    </script>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <script type="module" src="/scripts/auth-menu.js"></script>
  </body>
</html>

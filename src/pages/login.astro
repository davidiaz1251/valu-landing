---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Acceso | Valu Kraft" description="Inicia sesión para descargar plantillas y acceder a tu área de cliente.">
  <section class="auth section section--sm">
    <div class="container auth__container">
      <article class="auth-card">
        <h1>Iniciar sesión</h1>
        <p>Accede para ver y descargar plantillas según tu tipo de cuenta.</p>

        <div id="authAlert" class="auth-alert" hidden></div>

        <form id="loginForm" class="auth-form">
          <label>
            Correo electrónico
            <input type="email" name="email" required autocomplete="email" />
          </label>

          <label>
            Contraseña
            <input type="password" name="password" required minlength="6" autocomplete="current-password" />
          </label>

          <button class="btn btn--primary" type="submit">Entrar</button>
        </form>

        <button id="googleLogin" class="btn btn--secondary auth-google" type="button">Continuar con Google</button>

        <div class="auth-links">
          <a href="/registro">Crear cuenta</a>
          <a href="/olvide-contrasena">Olvidé mi contraseña</a>
        </div>
      </article>
    </div>
  </section>


<script type="module" src="/scripts/login.js"></script>

<style>
  .auth { padding-top: calc(var(--space-24) + var(--space-6)); }
  .auth__container { display: flex; justify-content: center; }
  .auth-card { width: 100%; max-width: 460px; background: #fff; border: 1px solid var(--color-gray-200); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); padding: var(--space-8); }
  .auth-form { display: grid; gap: var(--space-4); margin-top: var(--space-5); }
  .auth-form label { display: grid; gap: var(--space-2); font-weight: var(--font-medium); }
  .auth-form input { border: 1px solid var(--color-gray-300); border-radius: var(--radius-md); padding: var(--space-3); }
  .auth-google { width: 100%; margin-top: var(--space-3); }
  .auth-links { display: flex; justify-content: space-between; margin-top: var(--space-5); font-size: var(--text-sm); }
  .auth-alert { margin-top: var(--space-4); padding: var(--space-3); border-radius: var(--radius-md); background: #fff3f3; color: #9a1c1c; border: 1px solid #f3c5c5; }
</style>

</Layout>

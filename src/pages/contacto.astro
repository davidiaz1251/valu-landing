---
import Layout from '../layouts/Layout.astro';

const contactFaqs = [
  { q: '¿Cuánto tardáis en responder?', a: 'Normalmente respondemos en menos de 24 horas por WhatsApp o email.' },
  { q: '¿Puedo pedir presupuesto sin compromiso?', a: 'Sí, enviamos presupuesto orientativo sin compromiso tras revisar tu idea.' },
  { q: '¿Hacéis envíos en España?', a: 'Sí, trabajamos pedidos personalizados con envíos a España.' }
];

const contactFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: contactFaqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};
---

<Layout title="Contacto y pedidos | Valu Kraft" description="Contacta con Valu Kraft para solicitar presupuestos y pedidos personalizados por WhatsApp, email o formulario.">
  <script type="application/ld+json" set:html={JSON.stringify(contactFaqSchema)}></script>
  <section class="contact-hero section--lg">
    <div class="container">
      <div class="contact-hero__content">
        <span class="section__badge">Contacto</span>
        <h1>Hablemos de tu <span class="gradient-text">proyecto</span></h1>
        <p>Estamos aquí para ayudarte. Elige la forma que prefieras para contactarnos.</p>
      </div>
    </div>
  </section>

  <section class="contact-main section">
    <div class="container">
      <div class="contact-main__wrapper">
        <div class="contact-methods">
          <h2>Formas de contacto</h2>
          
          <a href="https://wa.me/34600000000" class="contact-card contact-card--whatsapp" target="_blank">
            <div class="contact-card__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <div class="contact-card__content">
              <h3>WhatsApp</h3>
              <p>Respuesta rápida. Ideal para consultas y encargos.</p>
              <span class="contact-card__link">+34 600 000 000 →</span>
            </div>
          </a>
          
          <a href="mailto:hola@valukraft.com" class="contact-card">
            <div class="contact-card__icon contact-card__icon--email">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <div class="contact-card__content">
              <h3>Email</h3>
              <p>Para consultas detalladas o envío de archivos.</p>
              <span class="contact-card__link">hola@valukraft.com →</span>
            </div>
          </a>
          
          <a href="https://instagram.com/valukraft" class="contact-card" target="_blank">
            <div class="contact-card__icon contact-card__icon--instagram">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div class="contact-card__content">
              <h3>Instagram</h3>
              <p>Síguenos y mándanos un DM.</p>
              <span class="contact-card__link">@valukraft →</span>
            </div>
          </a>
          
          <div class="contact-info">
            <div class="contact-info__item">
              <span class="contact-info__icon">⏰</span>
              <div>
                <h4>Horario</h4>
                <p>Lunes a Viernes: 9:00 - 18:00<br>Sábados: 10:00 - 14:00</p>
              </div>
            </div>
            <div class="contact-info__item">
              <span class="contact-info__icon">📍</span>
              <div>
                <h4>Ubicación</h4>
                <p>España</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="contact-form-wrapper">
          <h2>Envíanos un mensaje</h2>
          <form class="contact-form" id="contactForm">
            <div class="form-group">
              <label for="name">Nombre *</label>
              <input type="text" id="name" name="name" required placeholder="Tu nombre">
            </div>
            
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com">
            </div>
            
            <div class="form-group">
              <label for="phone">Teléfono</label>
              <input type="tel" id="phone" name="phone" placeholder="+34 600 000 000">
            </div>
            
            <div class="form-group">
              <label for="service">¿Qué necesitas?</label>
              <select id="service" name="service">
                <option value="">Selecciona una opción</option>
                <option value="papeleria">Papelería Creativa</option>
                <option value="toppers">Cake Toppers / Decoración</option>
                <option value="personalizacion">Personalización (textil, tazas...)</option>
                <option value="encuadernacion">Encuadernación</option>
                <option value="otro">Otro / No sé aún</option>
              </select>
            </div>
            
            <div class="form-group form-group--full">
              <label for="message">Cuéntanos tu idea *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Describe tu proyecto, evento, fecha aproximada..."></textarea>
            </div>
            
            <button type="submit" class="btn btn--primary btn--lg">
              Enviar mensaje
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2>Preguntas frecuentes de contacto y pedidos</h2>
      <div class="contact-faq">
        {contactFaqs.map((item) => (
          <article>
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero { padding-top: calc(var(--space-24) + 60px); text-align: center; }
  .contact-hero__content { max-width: 700px; margin: 0 auto; }
  .contact-hero__content h1 { margin-bottom: var(--space-6); }
  .contact-hero__content p { font-size: var(--text-xl); color: var(--color-gray-600); }

  .contact-main__wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); }

  .contact-methods h2, .contact-form-wrapper h2 { font-family: var(--font-primary); font-size: var(--text-2xl); margin-bottom: var(--space-6); }

  .contact-card { display: flex; gap: var(--space-5); padding: var(--space-6); background: var(--color-white); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); text-decoration: none; transition: all var(--transition-base); margin-bottom: var(--space-4); border: 2px solid transparent; }
  .contact-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-xl); }
  .contact-card--whatsapp { border-color: #25D366; }
  .contact-card--whatsapp:hover { background: linear-gradient(135deg, rgba(37, 211, 102, 0.1), rgba(37, 211, 102, 0.05)); }
  .contact-card__icon { width: 60px; height: 60px; border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center; background: #25D366; color: white; flex-shrink: 0; }
  .contact-card__icon--email { background: var(--color-primary); }
  .contact-card__icon--instagram { background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); }
  .contact-card__content h3 { font-family: var(--font-primary); font-size: var(--text-lg); color: var(--color-dark); margin-bottom: var(--space-1); }
  .contact-card__content p { font-size: var(--text-sm); color: var(--color-gray-500); margin-bottom: var(--space-2); }
  .contact-card__link { font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--color-primary-dark); }

  .contact-info { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-top: var(--space-6); }
  .contact-info__item { display: flex; gap: var(--space-3); padding: var(--space-4); background: var(--color-gray-100); border-radius: var(--radius-lg); }
  .contact-info__icon { font-size: var(--text-2xl); }
  .contact-info__item h4 { font-family: var(--font-primary); font-size: var(--text-sm); font-weight: var(--font-semibold); margin-bottom: var(--space-1); }
  .contact-info__item p { font-size: var(--text-sm); color: var(--color-gray-500); margin: 0; }

  .contact-form-wrapper { background: var(--color-white); padding: var(--space-8); border-radius: var(--radius-2xl); box-shadow: var(--shadow-lg); }
  .contact-form { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  .form-group { display: flex; flex-direction: column; gap: var(--space-2); }
  .form-group--full { grid-column: 1 / -1; }
  .form-group label { font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--color-dark); }
  .form-group input, .form-group select, .form-group textarea { padding: var(--space-4); background: var(--color-gray-100); border: 2px solid transparent; border-radius: var(--radius-lg); font-family: var(--font-primary); font-size: var(--text-base); color: var(--color-dark); transition: all var(--transition-fast); }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-white); }
  .form-group textarea { resize: vertical; min-height: 120px; }
  .contact-form button { grid-column: 1 / -1; justify-self: start; }

  @media (max-width: 992px) { .contact-main__wrapper { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .contact-form { grid-template-columns: 1fr; } .contact-info { grid-template-columns: 1fr; } .contact-form-wrapper { padding: var(--space-6); } }

  .contact-faq { display:grid; gap:.8rem; }
  .contact-faq article { background:#fff; border:1px solid #eadfdb; border-radius:12px; padding:.8rem 1rem; }
  .contact-faq h3{ margin:.1rem 0 .35rem; font-size:1rem;}
  .contact-faq p{ margin:0; color:var(--color-gray-600);}
</style>

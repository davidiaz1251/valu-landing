---
import Navbar from '../components/landing-clean/Navbar.astro';
import Hero from '../components/landing-clean/Hero.astro';
import Momentos from '../components/landing-clean/Momentos.astro';
import Proceso from '../components/landing-clean/Proceso.astro';
import Productos from '../components/landing-clean/Productos.astro';
import Personaliza from '../components/landing-clean/Personaliza.astro';
import Testimonios from '../components/landing-clean/Testimonios.astro';
import CTA from '../components/landing-clean/CTA.astro';
import Footer from '../components/landing-clean/Footer.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? 'https://wshszoghxaserycscvka.supabase.co';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? 'sb_publishable_JbFfvEa-5l8QISrKp6NUGQ_nfa8OrfQ';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" />
    <link rel="manifest" href="/manifest.json" />

    <title>Valu Kraft | Papelería creativa y personalizados</title>
    <meta name="description" content="Valu Kraft: papelería creativa y productos personalizados hechos a mano para celebraciones inolvidables." />
    <link rel="canonical" href="https://www.valukraft.com/" />
    <meta property="og:title" content="Valu Kraft" />
    <meta property="og:description" content="Papelería creativa hecha en Madrid con envíos a toda España para celebraciones memorables." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.valukraft.com/" />
    <meta property="og:image" content="https://www.valukraft.com/images/logo-valu-round.jpg" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
      <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
      window.__SUPABASE_URL = supabaseUrl || '';
      window.__SUPABASE_ANON_KEY = supabaseAnonKey || '';
    </script>
    <script is:inline>
      if (window.location.hash.includes('access_token=') && !window.location.pathname.startsWith('/auth/callback')) {
        const next = encodeURIComponent('/plantillas');
        window.location.replace('/auth/callback?next=' + next + window.location.hash);
      }
    </script>
</head>
  <body>
    <Navbar />
    <Hero />
    <Momentos />
    <Proceso />
    <Productos />
    <Personaliza />
    <Testimonios />
    <CTA />
    <Footer />
    <script type="module" src="/scripts/auth-menu.js"></script>
  </body>
</html>

<style is:global>
  :root {
    --background: hsl(30 33% 98%);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--background);
    color: #2f1f28;
    font-family: 'DM Sans', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  img { max-width: 100%; }
  a { transition: all .22s ease; }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Valu Kraft | Papelería Creativa y Personalización Artesanal">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__bg">
      <div class="blob blob--primary hero__blob hero__blob--1"></div>
      <div class="blob blob--secondary hero__blob hero__blob--2"></div>
      <div class="blob blob--accent hero__blob hero__blob--3"></div>
    </div>
    
    <div class="container">
      <div class="hero__content">
        <div class="hero__text">
          <span class="hero__badge">✨ Creatividad sin límites</span>
          <h1 class="hero__title">
            Transformamos <span class="gradient-text">ideas</span> en 
            <span class="gradient-text">recuerdos</span> únicos
          </h1>
          <p class="hero__description">
            En Valu Kraft creamos papelería creativa y productos personalizados 
            con amor, detalle y acabados profesionales. Cada proyecto es único, 
            como tu historia.
          </p>
          <div class="hero__cta">
            <a href="/productos" class="btn btn--primary btn--lg">
              Ver productos
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/encargos" class="btn btn--secondary btn--lg">
              Encargo personalizado
            </a>
          </div>
        </div>
        
        <div class="hero__visual">
          <div class="hero__card hero__card--1">
            <div class="hero__card-icon">🎁</div>
            <span>Cajas personalizadas</span>
          </div>
          <div class="hero__card hero__card--2">
            <div class="hero__card-icon">🎂</div>
            <span>Cake toppers</span>
          </div>
          <div class="hero__card hero__card--3">
            <div class="hero__card-icon">💌</div>
            <span>Invitaciones</span>
          </div>
          <div class="hero__card hero__card--4">
            <div class="hero__card-icon">👕</div>
            <span>Textiles personalizados</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="hero__scroll">
      <span>Descubre más</span>
      <div class="hero__scroll-indicator"></div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services section" id="servicios">
    <div class="container">
      <div class="section__header text-center">
        <span class="section__badge">Lo que hacemos</span>
        <h2 class="section__title">Creatividad para cada ocasión</h2>
        <p class="section__description">
          Desde papelería creativa hasta personalización de productos, 
          hacemos realidad tus ideas con calidad artesanal.
        </p>
      </div>
      
      <div class="services__grid">
        <div class="service-card">
          <div class="service-card__icon service-card__icon--pink">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
              <path d="m3.3 7 8.7 5 8.7-5"/>
              <path d="M12 22V12"/>
            </svg>
          </div>
          <h3 class="service-card__title">Papelería Creativa</h3>
          <p class="service-card__description">
            Cajitas, invitaciones, etiquetas, stickers y packaging personalizado 
            para tus eventos y celebraciones especiales.
          </p>
          <a href="/productos#papeleria" class="service-card__link">
            Explorar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        
        <div class="service-card">
          <div class="service-card__icon service-card__icon--blue">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3 class="service-card__title">Decoración de Eventos</h3>
          <p class="service-card__description">
            Cake toppers, decoración para mesas dulces, números, nombres y 
            figuras decorativas para hacer tu evento inolvidable.
          </p>
          <a href="/productos#decoracion" class="service-card__link">
            Explorar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        
        <div class="service-card">
          <div class="service-card__icon service-card__icon--lavender">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3c7.2 0 9 1.8 9 9s-1.8 9-9 9-9-1.8-9-9 1.8-9 9-9z"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <h3 class="service-card__title">Personalización</h3>
          <p class="service-card__description">
            Camisetas, tazas, termos, bolsas y regalos corporativos. 
            Llevamos tu diseño a cualquier producto.
          </p>
          <a href="/productos#personalizacion" class="service-card__link">
            Explorar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        
        <div class="service-card">
          <div class="service-card__icon service-card__icon--mint">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
            </svg>
          </div>
          <h3 class="service-card__title">Encuadernación</h3>
          <p class="service-card__description">
            Agendas, cuadernos artesanales, álbumes de recuerdos y 
            proyectos especiales a medida.
          </p>
          <a href="/productos#encuadernacion" class="service-card__link">
            Explorar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="values section">
    <div class="container">
      <div class="values__wrapper">
        <div class="values__content">
          <span class="section__badge">Por qué elegirnos</span>
          <h2 class="section__title">Más que productos, creamos experiencias</h2>
          <p class="section__description">
            En Valu Kraft no vendemos solo productos, creamos recuerdos. 
            Cada proyecto tiene nuestra dedicación, creatividad y pasión por los detalles.
          </p>
          
          <div class="values__list">
            <div class="value-item">
              <div class="value-item__icon">✨</div>
              <div class="value-item__content">
                <h4>Creatividad sin límites</h4>
                <p>Cada proyecto es único, no trabajamos con soluciones genéricas.</p>
              </div>
            </div>
            
            <div class="value-item">
              <div class="value-item__icon">💝</div>
              <div class="value-item__content">
                <h4>Personalización real</h4>
                <p>Adaptamos cada diseño a tu historia y tu ocasión especial.</p>
              </div>
            </div>
            
            <div class="value-item">
              <div class="value-item__icon">🎯</div>
              <div class="value-item__content">
                <h4>Calidad artesanal</h4>
                <p>Combinamos tecnología profesional con acabados hechos a mano.</p>
              </div>
            </div>
            
            <div class="value-item">
              <div class="value-item__icon">💕</div>
              <div class="value-item__content">
                <h4>Pasión por los detalles</h4>
                <p>Creemos que los pequeños detalles marcan la diferencia.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="values__visual">
          <div class="values__image-wrapper">
            <div class="values__decoration values__decoration--1"></div>
            <div class="values__decoration values__decoration--2"></div>
            <div class="values__stats">
              <div class="stat-card">
                <span class="stat-card__number">100%</span>
                <span class="stat-card__label">Personalizado</span>
              </div>
              <div class="stat-card">
                <span class="stat-card__number">500+</span>
                <span class="stat-card__label">Proyectos</span>
              </div>
              <div class="stat-card">
                <span class="stat-card__number">5⭐</span>
                <span class="stat-card__label">Valoración</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process section">
    <div class="container">
      <div class="section__header text-center">
        <span class="section__badge">Cómo trabajamos</span>
        <h2 class="section__title">Tu idea, hecha realidad</h2>
        <p class="section__description">
          Un proceso sencillo y colaborativo para crear juntos 
          algo especial y único.
        </p>
      </div>
      
      <div class="process__steps">
        <div class="process-step">
          <div class="process-step__number">01</div>
          <div class="process-step__content">
            <h3>Cuéntanos tu idea</h3>
            <p>Escríbenos por WhatsApp o formulario con tu idea, evento o proyecto. Cuéntanos lo que sueñas.</p>
          </div>
        </div>
        
        <div class="process-step">
          <div class="process-step__number">02</div>
          <div class="process-step__content">
            <h3>Diseñamos juntos</h3>
            <p>Creamos propuestas personalizadas adaptadas a tus gustos, colores y estilo.</p>
          </div>
        </div>
        
        <div class="process-step">
          <div class="process-step__number">03</div>
          <div class="process-step__content">
            <h3>Producimos con amor</h3>
            <p>Una vez aprobado el diseño, elaboramos tu pedido con materiales de calidad.</p>
          </div>
        </div>
        
        <div class="process-step">
          <div class="process-step__number">04</div>
          <div class="process-step__content">
            <h3>Lo recibes perfecto</h3>
            <p>Entregamos tu pedido listo para brillar en tu evento o sorprender a esa persona especial.</p>
          </div>
        </div>
      </div>
      
      <div class="process__cta text-center">
        <a href="/encargos" class="btn btn--primary btn--lg">
          Iniciar mi encargo
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section">
    <div class="container">
      <div class="section__header text-center">
        <span class="section__badge">Opiniones</span>
        <h2 class="section__title">Lo que dicen nuestros clientes</h2>
      </div>
      
      <div class="testimonials__grid">
        <div class="testimonial-card">
          <div class="testimonial-card__stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-card__text">
            "Las invitaciones de boda quedaron espectaculares. El trato fue increíble, 
            muy profesional y siempre pendientes de cada detalle. ¡100% recomendados!"
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">M</div>
            <div class="testimonial-card__info">
              <span class="testimonial-card__name">María García</span>
              <span class="testimonial-card__service">Invitaciones de Boda</span>
            </div>
          </div>
        </div>
        
        <div class="testimonial-card">
          <div class="testimonial-card__stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-card__text">
            "El cake topper para el cumple de mi hija fue precioso. Exactamente lo que pedí, 
            incluso mejor. Sin duda volveré a encargar."
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">L</div>
            <div class="testimonial-card__info">
              <span class="testimonial-card__name">Laura Martínez</span>
              <span class="testimonial-card__service">Decoración Cumpleaños</span>
            </div>
          </div>
        </div>
        
        <div class="testimonial-card">
          <div class="testimonial-card__stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-card__text">
            "Encargué camisetas personalizadas para mi empresa y el resultado fue perfecto. 
            Calidad excelente y entrega muy rápida."
          </p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">C</div>
            <div class="testimonial-card__info">
              <span class="testimonial-card__name">Carlos Ruiz</span>
              <span class="testimonial-card__service">Merchandising Empresarial</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container">
      <div class="cta__wrapper">
        <div class="cta__bg">
          <div class="blob cta__blob cta__blob--1"></div>
          <div class="blob cta__blob cta__blob--2"></div>
        </div>
        
        <div class="cta__content">
          <h2 class="cta__title">¿Tienes una idea en mente?</h2>
          <p class="cta__description">
            Cuéntanos tu proyecto y lo hacemos realidad juntos. 
            Cada encargo es único, como tú.
          </p>
          <div class="cta__buttons">
            <a href="https://wa.me/34600000000" class="btn btn--primary btn--lg" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              Contactar por WhatsApp
            </a>
            <a href="/contacto" class="btn btn--secondary btn--lg">
              Ver más opciones
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-24);
    overflow: hidden;
  }
  
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }
  
  .hero__blob {
    position: absolute;
    width: 600px;
    height: 600px;
  }
  
  .hero__blob--1 {
    top: -200px;
    right: -100px;
    background: var(--color-primary-light);
    animation: float 8s ease-in-out infinite;
  }
  
  .hero__blob--2 {
    bottom: -200px;
    left: -200px;
    background: var(--color-secondary-light);
    animation: float 10s ease-in-out infinite reverse;
  }
  
  .hero__blob--3 {
    top: 40%;
    left: 30%;
    width: 400px;
    height: 400px;
    background: var(--color-accent);
    animation: float 12s ease-in-out infinite;
  }
  
  .hero__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  
  .hero__text {
    max-width: 600px;
  }
  
  .hero__badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-white);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary-dark);
    box-shadow: var(--shadow-md);
    margin-bottom: var(--space-6);
    animation: fadeInUp 0.6s ease-out forwards;
  }
  
  .hero__title {
    margin-bottom: var(--space-6);
    animation: fadeInUp 0.6s ease-out 0.1s forwards;
    opacity: 0;
  }

  .hero__description {
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    margin-bottom: var(--space-8);
    animation: fadeInUp 0.6s ease-out 0.2s forwards;
    opacity: 0;
  }
  
  .hero__cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
    opacity: 0;
  }
  
  .hero__visual {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .hero__card {
    position: absolute;
    background: var(--color-white);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: var(--font-medium);
    transition: transform var(--transition-base);
    animation: float 6s ease-in-out infinite;
  }
  
  .hero__card:hover {
    transform: scale(1.05);
  }
  
  .hero__card-icon {
    font-size: var(--text-2xl);
  }
  
  .hero__card--1 {
    top: 10%;
    left: 10%;
    animation-delay: 0s;
  }
  
  .hero__card--2 {
    top: 25%;
    right: 5%;
    animation-delay: 1s;
  }
  
  .hero__card--3 {
    bottom: 25%;
    left: 5%;
    animation-delay: 2s;
  }
  
  .hero__card--4 {
    bottom: 10%;
    right: 15%;
    animation-delay: 3s;
  }
  
  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  
  .hero__scroll-indicator {
    width: 24px;
    height: 40px;
    border: 2px solid var(--color-gray-300);
    border-radius: var(--radius-full);
    position: relative;
  }
  
  .hero__scroll-indicator::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: var(--color-primary);
    border-radius: var(--radius-full);
    animation: scrollBounce 1.5s ease-in-out infinite;
  }
  
  @keyframes scrollBounce {
    0%, 100% { top: 8px; opacity: 1; }
    50% { top: 20px; opacity: 0.5; }
  }
  
  /* Section Header */
  .section__header {
    max-width: 600px;
    margin: 0 auto var(--space-12);
  }
  
  .section__badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-lavender));
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-4);
  }
  
  .section__title {
    margin-bottom: var(--space-4);
  }
  
  .section__description {
    color: var(--color-gray-500);
    font-size: var(--text-lg);
  }
  
  /* Services Section */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  
  .service-card {
    background: var(--color-white);
    padding: var(--space-8);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
  }
  
  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
  }
  
  .service-card__icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-5);
  }
  
  .service-card__icon--pink {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-peach));
    color: var(--color-primary-dark);
  }
  
  .service-card__icon--blue {
    background: linear-gradient(135deg, var(--color-secondary-light), var(--color-mint));
    color: var(--color-secondary-dark);
  }
  
  .service-card__icon--lavender {
    background: linear-gradient(135deg, var(--color-lavender), var(--color-primary-light));
    color: #8B6B96;
  }
  
  .service-card__icon--mint {
    background: linear-gradient(135deg, var(--color-mint), var(--color-sage));
    color: #5A8A7A;
  }
  
  .service-card__title {
    font-family: var(--font-primary);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-3);
  }
  
  .service-card__description {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    flex-grow: 1;
  }
  
  .service-card__link {
    display: inline-flex;
    align-items: center;

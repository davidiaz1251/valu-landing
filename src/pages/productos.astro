---
import Layout from '../layouts/Layout.astro';

const faqs = [
  { q: '¿Qué productos personalizados hace Valu Kraft?', a: 'Creamos toppers, papelería creativa, etiquetas, detalles para mesa y decoración personalizada para eventos.' },
  { q: '¿Cómo hago un pedido personalizado?', a: 'Puedes escribirnos por WhatsApp o desde contacto. Te pedimos idea, fecha, estilo y cantidad para enviarte propuesta.' },
  { q: '¿Con cuánto tiempo debo encargar?', a: 'Recomendamos pedir con al menos 2 a 4 semanas de antelación, según complejidad y volumen del pedido.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};
---

<Layout title="Productos personalizados para fiestas | Valu Kraft" description="Descubre toppers, papelería creativa, recuerdos y detalles personalizados de Valu Kraft. Encargos por WhatsApp e Instagram.">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <section class="products-hero section section--sm">
    <div class="container">
      <h1>Productos personalizados para cumpleaños, bodas y eventos</h1>
      <p class="section__description">
        Descubre nuestras categorías, mira ejemplos reales y pide tu versión personalizada por WhatsApp o Instagram.
      </p>
      <p id="catalog-status" class="catalog-status">Cargando catálogo…</p>
    </div>
  </section>

  <section class="products-tabs-wrap section">
    <div class="container">
      <div class="products-tabs" id="category-tabs"></div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div id="catalog-root" class="catalog-root"></div>
  </section>

  <section class="section seo-links">
    <div class="container">
      <h2>Explora por tipo de encargo</h2>
      <div class="seo-links__grid">
        <a href="/toppers-personalizados">Toppers personalizados para tartas</a>
        <a href="/papeleria-para-cumpleanos">Papelería personalizada para cumpleaños</a>
        <a href="/decoracion-personalizada-bodas">Decoración personalizada para bodas</a>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2>Preguntas frecuentes sobre pedidos personalizados</h2>
      <div class="faq-list">
        {faqs.map((item) => (
          <article class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script type="module" src="/scripts/productos-public.js"></script>
</Layout>

<style>
  .products-hero { padding-top: calc(var(--space-24) + var(--space-10)); padding-bottom: var(--space-6); }
  :global(.products-hero h1) { font-size: clamp(2rem, 4.8vw, 3.2rem); line-height: 1.05; letter-spacing: -0.01em; margin-bottom: .55rem; }
  .catalog-status { margin-top: .6rem; color: var(--color-gray-600); }

  .products-tabs-wrap { position: sticky; top: 72px; z-index: 20; padding-top: 0; padding-bottom: var(--space-6); }
  .products-tabs {
    display: flex;
    gap: .65rem;
    overflow-x: auto;
    padding: .5rem;
    border: 1px solid #eee;
    border-radius: 14px;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(8px);
  }

  :global(.tab-link) {
    border: 1px solid #e9e3e1;
    border-radius: 999px;
    padding: .5rem .9rem;
    white-space: nowrap;
    font-weight: 600;
    color: var(--color-gray-700);
    background: #fff;
  }

  .catalog-root { display: grid; gap: var(--space-10); }

  :global(.catalog-category) {
    background: linear-gradient(180deg,#fff 0%,#fffdfa 100%);
    border: 1px solid #efe7e3;
    border-radius: 20px;
    padding: 1rem;
  }

  :global(.catalog-category__head) {
    display: flex;
    align-items: center;
    gap: .8rem;
    margin-bottom: .9rem;
  }

  :global(.catalog-category__emoji) {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    font-size: 22px;
    background: #fff5f1;
    border: 1px solid #f2dfd8;
    flex: 0 0 auto;
  }

  :global(.catalog-category__head h2) { margin: 0; font-size: 1.25rem; }
  :global(.catalog-category__head p) { margin: 0; color: var(--color-gray-600); }

  :global(.catalog-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  :global(.product-card) {
    border: 1px solid #eadfdb;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  :global(.product-card__media) {
    aspect-ratio: 4/3;
    background: #faf7f5;
    position: relative;
  }

  :global(.product-card__media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(.product-card__placeholder) {
    height: 100%;
    display: grid;
    place-items: center;
    font-size: 2rem;
  }

  :global(.product-card__body) { padding: .9rem; display: grid; gap: .6rem; }
  :global(.product-card__title) { margin: 0; font-size: 1rem; }
  :global(.product-card__description) { margin: 0; color: var(--color-gray-600); font-size: .95rem; }

  :global(.product-card__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .5rem;
    margin-top: .2rem;
  }

  :global(.product-card__actions .btn) {
    justify-content: center;
    padding: .5rem .65rem;
    font-size: .86rem;
  }

  @media (max-width: 1024px) {
    :global(.catalog-grid) { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 680px) {
    .products-hero { padding-top: calc(var(--space-24) + var(--space-6)); }
    .products-tabs-wrap { top: 64px; }
    :global(.catalog-category) { padding: .85rem; border-radius: 16px; }
    :global(.catalog-grid) { grid-template-columns: 1fr; gap: .8rem; }
    :global(.product-card__actions) { grid-template-columns: 1fr; }
    :global(.catalog-category__head h2) { font-size: 1.1rem; }
  }

  .seo-links { padding-top: 0; }
  .seo-links h2 { margin: 0 0 .8rem; font-size: clamp(1.35rem, 3vw, 1.8rem); }
  .seo-links__grid { display:grid; gap:.6rem; }
  .seo-links__grid a { text-decoration:none; background:#fff; border:1px solid #eadfdb; border-radius:12px; padding:.8rem 1rem; color:#2d1c23; font-weight:600; }
  .seo-links__grid a:hover { background:#fff7f4; }

  .faq-list { display:grid; gap:.8rem; margin-top:.6rem; }
  .faq-item { background:#fff; border:1px solid #eadfdb; border-radius:12px; padding:.8rem 1rem; }
  .faq-item h3 { margin:.1rem 0 .35rem; font-size:1rem; }
  .faq-item p { margin:0; color:var(--color-gray-600); }
</style>

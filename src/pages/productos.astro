---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nuestros productos | Valu Kraft"
  description="Descubre el catálogo completo de productos personalizados de Valu Kraft."
>
  <section class="catalog section section--sm">
    <div class="container catalog__container">
      <header class="catalog__header">
        <div class="catalog__pill">
          <span>✨</span>
          <span>Catálogo completo</span>
        </div>

        <h1 class="catalog__title">Nuestros productos</h1>
        <p class="catalog__subtitle" id="catalogSubtitle">
          Cada pieza es hecha a mano y completamente personalizable. Escríbenos por WhatsApp para comenzar tu pedido.
        </p>
        <p id="catalogStatus" class="catalog__status">Cargando catálogo...</p>
      </header>

      <div id="catalogFilters" class="catalog__filters" hidden></div>

      <div id="catalogGrid" class="catalog__grid" hidden></div>

      <div id="catalogEmpty" class="catalog__empty" hidden></div>

      <section class="catalog-cta" id="catalogCta" hidden>
        <div class="catalog-cta__icon">✨</div>
        <h2>¿No encuentras lo que buscas?</h2>
        <p>
          Creamos diseños completamente personalizados. Cuéntanos tu idea y lo hacemos realidad.
        </p>
        <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer">Hablar con nosotras</a>
      </section>
    </div>
  </section>

  <script type="module" src="/scripts/productos-public.js?v=20260328d"></script>
</Layout>

<style>
  .catalog {
    padding-top: calc(var(--space-24) + var(--space-6));
    padding-bottom: var(--space-16);
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .catalog__header { margin-bottom: var(--space-8); }

  .catalog__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1.5px solid hsl(var(--border));
    background: hsl(var(--secondary));
    color: hsl(var(--secondary-foreground));
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .02em;
    text-transform: uppercase;
  }

  .catalog__title {
    margin: 14px 0 6px;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.875rem, 3.2vw, 2.25rem);
    line-height: 1.15;
    color: hsl(var(--foreground));
  }

  .catalog__subtitle {
    margin: 0;
    max-width: 640px;
    color: hsl(var(--muted-foreground));
    font-size: 1rem;
    line-height: 1.65;
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .catalog__status { margin-top: 8px; color: hsl(var(--muted-foreground)); font-size: .9rem; }

  .catalog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  :global(.catalog-filter-btn) {
    border: 1px solid hsl(var(--border) / .5);
    background: hsl(var(--card));
    color: hsl(var(--secondary-foreground));
    border-radius: 999px;
    padding: 7px 14px;
    font-size: .86rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s ease;
  }

  :global(.catalog-filter-btn.is-active) {
    background: hsl(var(--primary));
    border-color: hsl(var(--primary));
    color: hsl(var(--card));
  }

  :global(.catalog-filter-btn:hover) { border-color: hsl(var(--ring)); }

  .catalog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 680px) {
    .catalog__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 980px) {
    .catalog__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (min-width: 1200px) {
    .catalog__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  :global(.catalog-card) {
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
    display: flex;
    flex-direction: column;
  }

  :global(.catalog-card:hover) {
    transform: translateY(-2px);
    border-color: hsl(var(--border));
    box-shadow: var(--shadow-lg);
  }

  :global(.catalog-card__media) {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: hsl(var(--muted));
  }

  :global(.catalog-card__media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .45s ease;
  }

  :global(.catalog-card:hover .catalog-card__media img) { transform: scale(1.05); }

  :global(.catalog-card__tag) {
    position: absolute;
    top: 10px;
    left: 10px;
    border-radius: 999px;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card) / .9);
    backdrop-filter: blur(4px);
    padding: 5px 10px;
    font-size: .75rem;
    font-weight: 700;
    color: hsl(var(--secondary-foreground));
  }

  :global(.catalog-card__cat) {
    position: absolute;
    top: 10px;
    right: 10px;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: .75rem;
    font-weight: 700;
    border: 1px solid hsl(var(--border));
    backdrop-filter: blur(4px);
  }

  :global(.cat-toppers){ background: hsl(var(--accent) / .23); color: hsl(var(--accent-foreground)); }
  :global(.cat-invitaciones){ background: hsl(var(--secondary) / .8); color: hsl(var(--secondary-foreground)); }
  :global(.cat-cajas){ background: hsl(var(--primary) / .2); color: hsl(var(--primary)); }
  :global(.cat-regalos){ background: hsl(var(--primary) / .13); color: hsl(var(--primary)); }
  :global(.cat-default){ background: hsl(var(--muted)); color: hsl(var(--muted-foreground)); }

  :global(.catalog-card__body) {
    padding: 1.25rem;
    background: hsl(var(--card));
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  :global(.catalog-card__subtitle) { margin: 0; font-size: .75rem; color: hsl(var(--muted-foreground)); }

  :global(.catalog-card__title) {
    margin: 0;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.125rem;
    color: hsl(var(--foreground));
    line-height: 1.25;
  }

  :global(.catalog-card__desc) {
    margin: 0;
    font-size: .875rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    min-height: 44px;
  }

  :global(.catalog-card__meta) {
    margin-top: 1rem;
    padding-top: 1rem;
    min-height: 44px;
    border-top: 1px solid hsl(var(--border) / .75);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: .76rem;
    color: hsl(var(--muted-foreground));
  }

  :global(.catalog-card__rating strong) { color: hsl(var(--foreground)); }

  :global(.catalog-card__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 10px;
  }

  :global(.catalog-card__btn) {
    border-radius: 999px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: .625rem 1rem;
    font-size: .875rem;
    font-weight: 600;
    border: 1px solid hsl(var(--border));
    min-height: 42px;
    line-height: 1;
  }

  :global(.catalog-card__btn--ghost) { color: hsl(var(--foreground)); background: hsl(var(--card)); border: 1px solid hsl(var(--border)); }
  :global(.catalog-card__btn--ghost:hover) { background: hsl(var(--muted) / .85); }

  :global(.catalog-card__btn--primary) {
    border-color: hsl(var(--primary));
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
    box-shadow: 0 6px 16px hsl(var(--primary) / .2);
  }

  :global(.catalog-card__btn--primary:hover) { background: hsl(var(--primary)); }

  .catalog__empty {
    text-align: center;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    border-radius: 20px;
    padding: 44px 18px;
    max-width: 700px;
    margin: 0 auto;
  }

  .catalog-cta {
    margin-top: 56px;
    border: 1px solid hsl(var(--border));
    border-radius: 26px;
    padding: 36px 20px;
    text-align: center;
    background: linear-gradient(135deg, hsl(var(--secondary) / .5), hsl(var(--primary) / .2));
  }

  .catalog-cta__icon { font-size: 1.8rem; margin-bottom: 8px; }
  .catalog-cta h2 { margin: 0; font-family: 'Playfair Display', Georgia, serif; color: hsl(var(--foreground)); }
  .catalog-cta p { margin: 10px auto 0; max-width: 520px; color: hsl(var(--muted-foreground)); }
  .catalog-cta a {
    display: inline-flex;
    margin-top: 16px;
    text-decoration: none;
    border-radius: 999px;
    padding: 11px 18px;
    background: hsl(var(--primary));
    color: hsl(var(--card));
    font-weight: 600;
  }

  @media (max-width: 640px) {
    :global(.catalog-card__actions) { grid-template-columns: 1fr; }
  }
</style>

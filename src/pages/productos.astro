---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Productos personalizados para fiestas | Valu Kraft" description="Descubre toppers, papelería creativa, recuerdos y detalles personalizados de Valu Kraft. Encargos por WhatsApp e Instagram.">
  <section class="products-hero section section--sm">
    <div class="container">
      <h1>Productos hechos para momentos especiales</h1>
      <p class="section__description">
        Descubre nuestras categorías, mira ejemplos reales y pide tu versión personalizada por WhatsApp o Instagram.
      </p>
      <p id="catalog-status" class="catalog-status">Cargando catálogo…</p>
    </div>
  </section>

  <section class="products-tabs-wrap section">
    <div class="container">
      <div class="products-tabs" id="category-tabs"></div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div id="catalog-root" class="catalog-root"></div>
  </section>

  <script type="module" src="/scripts/productos-public.js"></script>
</Layout>

<style>
  .products-hero { padding-top: calc(var(--space-24) + var(--space-10)); padding-bottom: var(--space-6); }
  :global(.products-hero h1) { font-size: clamp(2rem, 4.8vw, 3.2rem); line-height: 1.05; letter-spacing: -0.01em; margin-bottom: .55rem; }
  .catalog-status { margin-top: .6rem; color: var(--color-gray-600); }

  .products-tabs-wrap { position: sticky; top: 72px; z-index: 20; padding-top: 0; padding-bottom: var(--space-6); }
  .products-tabs {
    display: flex;
    gap: .65rem;
    overflow-x: auto;
    padding: .5rem;
    border: 1px solid #eee;
    border-radius: 14px;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(8px);
  }

  :global(.tab-link) {
    border: 1px solid #e9e3e1;
    border-radius: 999px;
    padding: .5rem .9rem;
    white-space: nowrap;
    font-weight: 600;
    color: var(--color-gray-700);
    background: #fff;
  }

  .catalog-root { display: grid; gap: var(--space-10); }

  :global(.catalog-category) {
    background: linear-gradient(180deg,#fff 0%,#fffdfa 100%);
    border: 1px solid #efe7e3;
    border-radius: 20px;
    padding: 1rem;
  }

  :global(.catalog-category__head) {
    display: flex;
    align-items: center;
    gap: .8rem;
    margin-bottom: .9rem;
  }

  :global(.catalog-category__emoji) {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    font-size: 22px;
    background: #fff5f1;
    border: 1px solid #f2dfd8;
    flex: 0 0 auto;
  }

  :global(.catalog-category__head h2) { margin: 0; font-size: 1.25rem; }
  :global(.catalog-category__head p) { margin: 0; color: var(--color-gray-600); }

  :global(.catalog-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  :global(.product-card) {
    border: 1px solid #eadfdb;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  :global(.product-card__media) {
    aspect-ratio: 4/3;
    background: #faf7f5;
    position: relative;
  }

  :global(.product-card__media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(.product-card__placeholder) {
    height: 100%;
    display: grid;
    place-items: center;
    font-size: 2rem;
  }

  :global(.product-card__body) { padding: .9rem; display: grid; gap: .6rem; }
  :global(.product-card__title) { margin: 0; font-size: 1rem; }
  :global(.product-card__description) { margin: 0; color: var(--color-gray-600); font-size: .95rem; }

  :global(.product-card__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .5rem;
    margin-top: .2rem;
  }

  :global(.product-card__actions .btn) {
    justify-content: center;
    padding: .5rem .65rem;
    font-size: .86rem;
  }

  @media (max-width: 1024px) {
    :global(.catalog-grid) { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 680px) {
    .products-hero { padding-top: calc(var(--space-24) + var(--space-6)); }
    .products-tabs-wrap { top: 64px; }
    :global(.catalog-category) { padding: .85rem; border-radius: 16px; }
    :global(.catalog-grid) { grid-template-columns: 1fr; gap: .8rem; }
    :global(.product-card__actions) { grid-template-columns: 1fr; }
    :global(.catalog-category__head h2) { font-size: 1.1rem; }
  }
</style>

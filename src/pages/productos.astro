---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Productos | Valu Kraft" description="Catálogo de productos de Valu Kraft. Pedidos por WhatsApp e Instagram.">
  <section class="section section--lg">
    <div class="container">
      <span class="section__badge">Catálogo</span>
      <h1>Productos Valu Kraft</h1>
      <p class="section__description">Catálogo visual sin precios. Pide información por WhatsApp o Instagram.</p>
      <p id="catalog-status" class="catalog-status">Cargando catálogo…</p>
    </div>
  </section>

  <section class="section">
    <div class="container tabs" id="category-tabs"></div>
  </section>

  <div id="catalog-root"></div>

  <script type="module" src="/scripts/productos-public.js"></script>
</Layout>

<style>
  .tabs { display: flex; flex-wrap: wrap; gap: .75rem; }
  .tab-link { background: #fff; border: 1px solid #e6e6e6; border-radius: 999px; padding: .55rem .9rem; color: var(--color-gray-700); font-weight: 600; }
  .catalog-status { margin-top: .6rem; color: var(--color-gray-600); }
  .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; margin-top: 1.25rem; }
  .product-card { background: #fff; border: 1px solid #ececec; border-radius: 1rem; overflow: hidden; display: flex; flex-direction: column; }
  .product-card__media { aspect-ratio: 4 / 3; background: #fafafa; }
  .product-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .product-card__placeholder { height: 100%; display: grid; place-items: center; color: #999; font-weight: 600; }
  .product-card__body { padding: 1rem; display: grid; gap: .65rem; }
  .product-card__body h3 { margin: 0; }
  .product-card__body p { margin: 0; color: var(--color-gray-600); }
  .product-badge { font-size: .8rem; width: max-content; border-radius: 999px; background: #f3e8ff; color: #6b21a8; padding: .25rem .6rem; font-weight: 700; }
  .product-card__actions { display: grid; gap: .55rem; }
  .product-card__actions .btn { justify-content: center; }
</style>

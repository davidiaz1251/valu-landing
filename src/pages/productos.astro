---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nuestros productos | Valu Kraft"
  description="Descubre el catálogo completo de productos personalizados de Valu Kraft."
>
  <section class="catalog section section--sm">
    <div class="container catalog__container">
      <header class="catalog__header">
        <div class="catalog__pill">
          <span>✨</span>
          <span>Catálogo completo</span>
        </div>

        <h1 class="catalog__title">Nuestros productos</h1>
        <p class="catalog__subtitle" id="catalogSubtitle">
          Cada pieza es hecha a mano y completamente personalizable. Escríbenos por WhatsApp para comenzar tu pedido.
        </p>
        <p id="catalogStatus" class="catalog__status">Cargando catálogo...</p>
      </header>

      <div id="catalogFilters" class="catalog__filters" hidden></div>

      <div id="catalogGrid" class="catalog__grid" hidden></div>

      <div id="catalogEmpty" class="catalog__empty" hidden></div>

      <section class="catalog-cta" id="catalogCta" hidden>
        <div class="catalog-cta__icon">✨</div>
        <h2>¿No encuentras lo que buscas?</h2>
        <p>
          Creamos diseños completamente personalizados. Cuéntanos tu idea y lo hacemos realidad.
        </p>
        <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer">Hablar con nosotras</a>
      </section>
    </div>
  </section>

  <script type="module" src="/scripts/productos-public.js?v=20260328d"></script>
</Layout>

<style>
  .catalog {
    padding-top: calc(var(--space-24) + var(--space-6));
    padding-bottom: var(--space-16);
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .catalog__header { margin-bottom: var(--space-8); }

  .catalog__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(220,206,198,.95);
    background: rgba(250,243,239,.85);
    color: #5f4a54;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .02em;
    text-transform: uppercase;
  }

  .catalog__title {
    margin: 14px 0 6px;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.875rem, 3.2vw, 2.25rem);
    line-height: 1.15;
    color: #2f1f28;
  }

  .catalog__subtitle {
    margin: 0;
    max-width: 640px;
    color: #6b5963;
    font-size: 1rem;
    line-height: 1.65;
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .catalog__status { margin-top: 8px; color: #8a7780; font-size: .9rem; }

  .catalog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  :global(.catalog-filter-btn) {
    border: 1px solid rgba(228,218,213,.95);
    background: hsl(var(--card));
    color: #6f5a64;
    border-radius: 999px;
    padding: 7px 14px;
    font-size: .86rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s ease;
  }

  :global(.catalog-filter-btn.is-active) {
    background: hsl(160 30% 45%);
    border-color: hsl(160 30% 45%);
    color: #fff;
  }

  :global(.catalog-filter-btn:hover) { border-color: hsla(160,30%,45%,.45); }

  .catalog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 680px) {
    .catalog__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 980px) {
    .catalog__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (min-width: 1200px) {
    .catalog__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  :global(.catalog-card) {
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 24px rgba(53,27,35,.07);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
    display: flex;
    flex-direction: column;
  }

  :global(.catalog-card:hover) {
    transform: translateY(-2px);
    border-color: rgba(210,182,170,.95);
    box-shadow: 0 16px 32px rgba(53,27,35,.12);
  }

  :global(.catalog-card__media) {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: hsl(var(--muted));
  }

  :global(.catalog-card__media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .45s ease;
  }

  :global(.catalog-card:hover .catalog-card__media img) { transform: scale(1.05); }

  :global(.catalog-card__tag) {
    position: absolute;
    top: 10px;
    left: 10px;
    border-radius: 999px;
    border: 1px solid rgba(228,218,213,.9);
    background: hsl(var(--card));
    padding: 5px 10px;
    font-size: .72rem;
    font-weight: 700;
    color: #5f4a54;
  }

  :global(.catalog-card__cat) {
    position: absolute;
    top: 10px;
    right: 10px;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: .72rem;
    font-weight: 700;
  }

  :global(.cat-toppers){ background: hsla(42,65%,65%,.23); color: #7a5a2f; }
  :global(.cat-invitaciones){ background: hsla(350,40%,90%,.65); color: #754f60; }
  :global(.cat-cajas){ background: hsla(160,30%,85%,.65); color: #365f56; }
  :global(.cat-regalos){ background: hsla(160,30%,45%,.13); color: #2f6f59; }
  :global(.cat-default){ background: #f3ece9; color: #7b6770; }

  :global(.catalog-card__body) {
    padding: 16px;
    background: linear-gradient(180deg, rgba(255,255,255,.55) 0%, rgba(255,255,255,.35) 100%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  :global(.catalog-card__subtitle) { margin: 0; font-size: .78rem; color: #8a7780; }

  :global(.catalog-card__title) {
    margin: 0;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.05rem;
    color: #2f1f28;
    line-height: 1.25;
  }

  :global(.catalog-card__desc) {
    margin: 0;
    font-size: .85rem;
    color: #6b5963;
    line-height: 1.55;
    min-height: 44px;
  }

  :global(.catalog-card__meta) {
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid rgba(228,218,213,.65);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: .76rem;
    color: #8a7780;
  }

  :global(.catalog-card__rating strong) { color: #2f1f28; }

  :global(.catalog-card__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 10px;
  }

  :global(.catalog-card__btn) {
    border-radius: 999px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 12px;
    font-size: .83rem;
    font-weight: 600;
    border: 1px solid rgba(228,218,213,.9);
  }

  :global(.catalog-card__btn--ghost) { color: #4f3d46; background: hsl(var(--card)); }
  :global(.catalog-card__btn--ghost:hover) { background: rgba(248,242,238,.85); }

  :global(.catalog-card__btn--primary) {
    border-color: hsl(160 30% 45%);
    background: hsl(160 30% 45%);
    color: #fff;
  }

  :global(.catalog-card__btn--primary:hover) { background: hsl(160 30% 42%); }

  .catalog__empty {
    text-align: center;
    border: 1px solid #eadfdb;
    background: hsl(var(--card));
    border-radius: 20px;
    padding: 44px 18px;
    max-width: 700px;
    margin: 0 auto;
  }

  .catalog-cta {
    margin-top: 56px;
    border: 1px solid rgba(228,218,213,.65);
    border-radius: 26px;
    padding: 36px 20px;
    text-align: center;
    background: linear-gradient(135deg, rgba(212,232,245,.4), rgba(184,224,212,.25));
  }

  .catalog-cta__icon { font-size: 1.8rem; margin-bottom: 8px; }
  .catalog-cta h2 { margin: 0; font-family: 'Playfair Display', Georgia, serif; color: #2f1f28; }
  .catalog-cta p { margin: 10px auto 0; max-width: 520px; color: #6b5963; }
  .catalog-cta a {
    display: inline-flex;
    margin-top: 16px;
    text-decoration: none;
    border-radius: 999px;
    padding: 11px 18px;
    background: hsl(160 30% 45%);
    color: #fff;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    :global(.catalog-card__actions) { grid-template-columns: 1fr; }
  }
</style>

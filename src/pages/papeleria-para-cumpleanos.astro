---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Papelería personalizada para cumpleaños | Valu Kraft" description="Invitaciones, etiquetas, toppers y decoración de mesa personalizada para cumpleaños infantiles y adultos.">
  <section class="section section--lg">
    <div class="container page">
      <span class="section__badge">Cumpleaños</span>
      <h1>Papelería personalizada para cumpleaños</h1>
      <p class="lead">Preparamos una línea visual completa para que tu cumple se vea coherente, bonito y memorable.</p>
      <h2>Incluye</h2>
      <ul>
        <li>Invitaciones personalizadas</li>
        <li>Topper para tarta</li>
        <li>Etiquetas y stickers</li>
        <li>Cartelería y detalles de mesa</li>
      </ul>
      <p><a href="/contacto" class="btn btn--primary">Pedir presupuesto</a></p>
    </div>
  </section>
</Layout>

<style>
  .page{max-width:820px}
  .lead{font-size:1.12rem;color:var(--color-gray-600)}
</style>

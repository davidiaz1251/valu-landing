---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Decoración personalizada para bodas | Valu Kraft" description="Diseño artesanal para bodas: papelería, carteles, topper y detalles personalizados para una celebración única.">
  <section class="section section--lg">
    <div class="container page">
      <span class="section__badge">Bodas</span>
      <h1>Decoración personalizada para bodas</h1>
      <p class="lead">En Valu Kraft diseñamos piezas personalizadas para bodas con estilo elegante y acabados artesanales.</p>
      <h2>Servicios frecuentes</h2>
      <ul>
        <li>Invitaciones y papelería de mesa</li>
        <li>Carteles de bienvenida</li>
        <li>Topper de boda personalizado</li>
        <li>Detalles y recuerdos para invitados</li>
      </ul>
      <p><a href="/encargos" class="btn btn--primary">Empezar mi encargo de boda</a></p>
    </div>
  </section>
</Layout>

<style>
  .page{max-width:820px}
  .lead{font-size:1.12rem;color:var(--color-gray-600)}
</style>

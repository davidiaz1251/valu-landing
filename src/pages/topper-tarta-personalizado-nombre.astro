---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Topper de tarta personalizado con nombre | Valu Kraft" description="Topper de tarta personalizado con nombre, edad o frase. Diseños artesanales para cumpleaños y celebraciones.">
  <section class="section section--lg">
    <div class="container page">
      <span class="section__badge">Topper con nombre</span>
      <h1>Topper de tarta personalizado con nombre</h1>
      <p class="lead">Diseñamos toppers de tarta personalizados con nombre para cumpleaños, aniversarios y eventos especiales.</p>
      <p><a href="/contacto" class="btn btn--primary">Solicitar topper con nombre</a></p>
    </div>
  </section>
</Layout>

<style>.page{max-width:820px}.lead{font-size:1.12rem;color:var(--color-gray-600)}</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Panel admin · Plantillas | Valu Kraft" description="Gestión interna de archivos de plantillas.">
  <section class="section section--sm" style="padding-top: calc(var(--space-24) + var(--space-8));">
    <div class="container admin-wrap">
      <h1>Panel de plantillas</h1>
      <p id="adminStatus" class="admin-status">Comprobando acceso…</p>

      <div id="adminApp" hidden>
        <form id="uploadForm" class="admin-upload">
          <label>
            Selecciona archivo
            <input type="file" id="fileInput" required />
          </label>
          <label>
            Carpeta (opcional)
            <input type="text" id="folderInput" placeholder="ej: temporada-mayo" />
          </label>
          <button class="btn btn--primary" type="submit">Subir archivo</button>
        </form>

        <h2>Archivos en bucket templates</h2>
        <div id="filesList" class="admin-files">Cargando archivos…</div>
      </div>
    </div>
  </section>
  <script type="module" src="/scripts/admin-plantillas.js"></script>
</Layout>

<style>
  .admin-wrap { max-width: 980px; }
  .admin-status { margin: 10px 0 20px; }
  .admin-upload { display:grid; gap:12px; background:#fff; border:1px solid var(--color-gray-200); border-radius:12px; padding:16px; margin-bottom:20px; }
  .admin-upload label { display:grid; gap:6px; }
  .admin-upload input { border:1px solid var(--color-gray-300); border-radius:8px; padding:10px; }
  .admin-files { display:grid; gap:8px; }
  .admin-file { display:flex; justify-content:space-between; gap:8px; align-items:center; border:1px solid var(--color-gray-200); border-radius:10px; padding:10px; background:#fff; }
  .admin-file code { font-size:12px; color:#555; }
  .admin-actions { display:flex; gap:8px; }
  .btn-mini { border:1px solid var(--color-gray-300); border-radius:8px; background:#fff; padding:6px 10px; cursor:pointer; }
  .btn-mini.danger { border-color:#e9b1b1; color:#9b1c1c; }
</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Productos | Valu Kraft" description="Panel para gestionar categorías y productos del catálogo.">
  <section class="section section--lg">
    <div class="container admin-header">
      <h1>Panel admin · Catálogo</h1>
      <p>Gestiona categorías y productos en Supabase.</p>
      <p id="adminProductsStatus" class="admin-sub">Comprobando acceso…</p>
    </div>
  </section>

  <section class="section">
    <div class="container admin-grid" id="adminProductsApp" hidden>
      <main class="admin-card">
        <div class="list-header">
          <h2>Categorías</h2>
          <button class="btn btn--primary" type="button" id="new-category-btn">Nueva categoría</button>
        </div>
        <div id="category-list"></div>
      </main>

      <main class="admin-card">
        <div class="list-header">
          <h2>Productos</h2>
          <div class="admin-actions">
            <button class="btn btn--primary" type="button" id="new-product-btn">Nuevo producto</button>
            <a href="/productos" class="btn btn--secondary" target="_blank">Ver catálogo público</a>
          </div>
        </div>
        <div id="product-list"></div>
      </main>
    </div>
  </section>

  <div id="categoryModal" class="modal" hidden>
    <div class="modal__backdrop" data-close-category-modal></div>
    <div class="modal__card">
      <h3 id="category-modal-title">Nueva categoría</h3>
      <form id="category-form" class="admin-form">
        <input type="hidden" name="id" />
        <label>ID (slug)
          <input type="text" name="slug" placeholder="papeleria" />
        </label>
        <label>Título
          <input type="text" name="title" required />
        </label>
        <label>Descripción
          <textarea name="description" rows="3"></textarea>
        </label>
        <label>Ícono
          <input type="text" name="icon" placeholder="🎁" maxlength="4" />
        </label>
        <label>Orden
          <input type="number" name="sort_order" min="1" step="1" value="1" />
        </label>
        <label class="checkline">
          <input type="checkbox" name="is_active" checked /> Activa
        </label>
        <div class="admin-actions admin-actions--end">
          <button class="btn btn--secondary" type="button" data-close-category-modal>Cancelar</button>
          <button class="btn btn--primary" type="submit">Guardar categoría</button>
        </div>
      </form>
    </div>
  </div>

  <div id="productModal" class="modal" hidden>
    <div class="modal__backdrop" data-close-product-modal></div>
    <div class="modal__card">
      <h3 id="product-modal-title">Nuevo producto</h3>
      <form id="product-form" class="admin-form">
        <input type="hidden" name="id" />
        <label>Nombre
          <input type="text" name="name" required />
        </label>
        <label>Categoría
          <select name="category_id" required id="product-category-select"></select>
        </label>
        <label>Descripción
          <textarea name="description" rows="4"></textarea>
        </label>
        <label>Orden
          <input type="number" name="sort_order" min="1" step="1" value="1" />
        </label>
        <label class="checkline">
          <input type="checkbox" name="is_active" checked /> Activo
        </label>
        <div class="admin-actions admin-actions--end">
          <button class="btn btn--secondary" type="button" data-close-product-modal>Cancelar</button>
          <button class="btn btn--primary" type="submit">Guardar producto</button>
        </div>
      </form>
    </div>
  </div>

  <script type="module" src="/scripts/admin-productos.js"></script>
</Layout>

<style>
  .admin-grid { display:grid; gap:14px; }
  .admin-card { background:#fff; border:1px solid #ececec; border-radius:1rem; padding:1rem; }
  .admin-form { display:grid; gap:.65rem; }
  .admin-form input, .admin-form select, .admin-form textarea { width:100%; border:1px solid #ddd; border-radius:.6rem; padding:.55rem .65rem; }
  .checkline { display:flex; gap:.5rem; align-items:center; }
  .checkline input { width:auto; }
  .admin-actions { display:flex; flex-wrap:wrap; gap:.55rem; margin-top:.45rem; }
  .admin-actions--end { justify-content:flex-end; }
  .list-header { display:flex; justify-content:space-between; align-items:center; gap:.75rem; margin-bottom:.75rem; flex-wrap:wrap; }
  .admin-sub { color:#666; }

  :global(.list-item) { display:flex; justify-content:space-between; gap:.75rem; border:1px solid #ececec; border-radius:.8rem; padding:.8rem; margin-bottom:.7rem; }
  :global(.list-item h3) { margin:0 0 .25rem; }
  :global(.list-item p) { margin:0 0 .25rem; color:var(--color-gray-600); }
  :global(.item-actions) { display:grid; gap:.4rem; align-content:start; }

  .modal[hidden] { display:none; }
  .modal { position: fixed; inset: 0; z-index: 2000; }
  .modal__backdrop { position:absolute; inset:0; background:rgba(20,20,20,.45); }
  .modal__card { position:relative; max-width:620px; margin:6vh auto 0; background:#fff; border:1px solid #ececec; border-radius:14px; padding:1rem; box-shadow:0 24px 48px rgba(0,0,0,.2); }
</style>

---
import Navbar from '../components/landing-clean/Navbar.astro';
import Footer from '../components/landing-clean/Footer.astro';
import { Heart, Share2, MessageCircle, Palette, Sparkles, Clock3, Layers, Wand2, Package, BadgeCheck, ArrowRight } from '@lucide/astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=20260328b" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=20260328b" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=20260328b" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260328b" />
    <title>Detalle de producto | Valu Kraft</title>
    <meta name="description" content="Personaliza tu producto en Valu Kraft: diseño artesanal, materiales premium y producción cuidada." />
    <link rel="canonical" href="https://www.valukraft.com/producto" />
    <meta property="og:title" content="Detalle de producto | Valu Kraft" />
    <meta property="og:description" content="Personaliza tu producto en Valu Kraft con acabados artesanales." />
    <meta property="og:type" content="product" />
    <meta property="og:url" content="https://www.valukraft.com/producto" />
    <meta property="og:image" content="https://www.valukraft.com/images/logo-valu-round.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar />

    <main class="pd-main">
      <section class="pd-breadcrumb wrap pd-reveal pd-reveal--up">
        <nav>
          <a href="/">Inicio</a>
          <span>›</span>
          <a href="/#productos">Productos</a>
          <span>›</span>
          <strong data-product-title>Toppers Personalizados</strong>
        </nav>
      </section>

      <section class="pd-hero wrap">
        <div class="pd-grid">
          <div class="pd-gallery pd-reveal pd-reveal--left" style="--d:0s;--dur:.6s">
            <div class="pd-gallery__main">
              <div class="pd-gallery__paper pd-gallery__paper--a"></div>
              <div class="pd-gallery__paper pd-gallery__paper--b"></div>
              <img id="pdMainImage" src="" alt="Producto" />
              <button id="pdPrev" class="pd-gallery__arrow">‹</button>
              <button id="pdNext" class="pd-gallery__arrow is-right">›</button>
              <div id="pdDots" class="pd-gallery__dots"></div>
            </div>
            <div id="pdThumbs" class="pd-gallery__thumbs"></div>
          </div>

          <aside class="pd-info pd-reveal pd-reveal--right" style="--d:.2s;--dur:.6s">
            <div class="pd-top">
              <div class="pd-tags">
                <span id="pdTag" class="pd-tag"></span>
                <span class="pd-tag is-hand">Hecho a mano</span>
              </div>
              <div class="pd-actions"><button id="pdLike" class="pd-like" aria-label="Favorito"><Heart size={16} /></button><button id="pdShare" class="pd-like" aria-label="Compartir"><Share2 size={16} /></button></div>
            </div>

            <h1 data-product-title>Toppers Personalizados</h1>
            <p id="pdTagline" class="pd-tagline"></p>

            <div class="pd-rating">
              <span>★★★★★</span>
              <small id="pdReviews"></small>
            </div>

            <div class="pd-divider"></div>

            <div class="pd-options">
              <div>
                <label>Estilo: <b id="pdStyleCurrent"></b></label>
                <div id="pdStyles" class="pd-chips"></div>
              </div>
              <div>
                <label>Ocasión: <b id="pdOccasionCurrent"></b></label>
                <div id="pdOccasions" class="pd-chips"></div>
              </div>
              <div>
                <label>Cantidad <small id="pdMinOrder"></small></label>
                <div class="pd-qty">
                  <button id="pdMinus">−</button>
                  <b id="pdQtyValue">1</b>
                  <button id="pdPlus">+</button>
                </div>
              </div>
            </div>

            <div id="pdIncludes" class="pd-includes"></div>
            <p class="pd-delivery"><Clock3 size={16} /> Tiempo de entrega: <b id="pdDelivery"></b></p>

            <div class="pd-cta">
              <a href="https://wa.me/" target="_blank" rel="noopener noreferrer" class="is-primary"><MessageCircle size={16} /> Pedir por WhatsApp</a>
              <a href="https://wa.me/" target="_blank" rel="noopener noreferrer" class="is-ghost"><Palette size={16} /> Personalizar</a>
            </div>
            <p class="pd-trust"><Sparkles size={14} /> Diseño personalizado sin costo adicional · Apruebas antes de producir</p>
          </aside>
        </div>
      </section>

      <section class="pd-features pd-reveal pd-reveal--up" style="--d:.15s">
        <div class="wrap">
          <div class="pd-features__head pd-reveal pd-reveal--up" style="--d:0s;--dur:.6s">
            <h2>¿Por qué elegir Valu Kraft?</h2>
          </div>
          <div class="pd-features__grid">
            <article class="pd-feature-card pd-reveal pd-reveal--up" style="--d:.1s;--dur:.5s"><div class="pd-feature-icon"><Wand2 size={20} /></div><h3>Diseño 100% personalizado</h3><p>Trabajamos contigo en cada detalle del diseño. Tu visión, nuestra magia.</p></article>
            <article class="pd-feature-card pd-reveal pd-reveal--up" style="--d:.2s;--dur:.5s"><div class="pd-feature-icon"><Layers size={20} /></div><h3>Materiales premium</h3><p>Cartulina glitter, acrílico, papel de alta gramaje. Solo lo mejor para tu momento.</p></article>
            <article class="pd-feature-card pd-reveal pd-reveal--up" style="--d:.3s;--dur:.5s"><div class="pd-feature-icon"><BadgeCheck size={20} /></div><h3>Apruebas antes de producir</h3><p>Te enviamos la prueba digital y solo procedemos cuando estás 100% feliz.</p></article>
            <article class="pd-feature-card pd-reveal pd-reveal--up" style="--d:.4s;--dur:.5s"><div class="pd-feature-icon"><Package size={20} /></div><h3>Empaque de regalo</h3><p>Cada pedido llega protegido y empacado con cariño, listo para sorprender.</p></article>
          </div>
        </div>
      </section>

      <section class="pd-related pd-reveal pd-reveal--up" style="--d:.25s">
        <div class="wrap">
          <div class="pd-related__head pd-reveal pd-reveal--up" style="--d:0s;--dur:.6s">
            <h2>También te puede gustar</h2>
            <a href="/#productos" class="pd-related__all">Ver todos <ArrowRight size={14} /></a>
          </div>
          <div id="pdRelated" class="pd-related__grid"></div>
        </div>
      </section>
    </main>

    <Footer />

    <script is:inline>
      const PRODUCTS_DATA = {
        toppers:{id:"toppers",title:"Toppers Personalizados",tag:"Más popular",rating:5,reviewCount:134,tagline:"El detalle que convierte un pastel en un momento",images:["https://media.base44.com/images/public/69c11d14bba13990f133d6d0/444014269_generated_image.png","https://media.base44.com/images/public/69c11d14bba13990f133d6d0/375ef7cc7_generated_image.png","https://media.base44.com/images/public/69c11d14bba13990f133d6d0/d3446ddef_generated_image.png","https://media.base44.com/images/public/69c11d14bba13990f133d6d0/ebddf5bd0_generated_image.png"],styles:["Glitter Dorado","Glitter Rosa","Acrílico Transparente","Papel Premium"],occasions:["Bodas","Cumpleaños","Baby Shower","Aniversario","Graduación"],includes:["Diseño personalizado incluido","Palillo de soporte dorado incluido","Empaque de regalo","Envío en caja protegida"],deliveryDays:"3–5 días hábiles",minOrder:1},
        invitaciones:{id:"invitaciones",title:"Invitaciones Premium",tag:"Nuevo diseño",rating:5,reviewCount:89,tagline:"La primera impresión de tu celebración",images:["https://media.base44.com/images/public/69c11d14bba13990f133d6d0/857462f94_generated_dffdc014.png","https://media.base44.com/images/public/69c11d14bba13990f133d6d0/296b37a14_generated_5a63a946.png"],styles:["Foil Dorado","Corte Láser","Acuarela","Minimalista"],occasions:["Bodas","XV Años","Baby Shower","Cumpleaños","Corporativo"],includes:["Diseño personalizado incluido","Sobres a juego","Set mínimo de 20 piezas","Prueba digital antes de imprimir"],deliveryDays:"5–7 días hábiles",minOrder:20},
        cajas:{id:"cajas",title:"Cajas y Packaging",tag:null,rating:5,reviewCount:61,tagline:"Porque la presentación también es parte del regalo",images:["https://media.base44.com/images/public/69c11d14bba13990f133d6d0/c10e70a5b_generated_c64166fd.png","https://media.base44.com/images/public/69c11d14bba13990f133d6d0/ebddf5bd0_generated_image.png"],styles:["Kraft Natural","Blanco Premium","Pastel Personalizado","Negro Elegante"],occasions:["Bodas","Baby Shower","Cumpleaños","Empresarial","San Valentín"],includes:["Diseño exterior personalizado","Papel tissue interior incluido","Cinta decorativa","Tarjeta de mensaje"],deliveryDays:"4–6 días hábiles",minOrder:5},
        regalos:{id:"regalos",title:"Regalos Personalizados",tag:"Exclusivo",rating:5,reviewCount:48,tagline:"Un regalo que nadie más podría dar",images:["https://media.base44.com/images/public/69c11d14bba13990f133d6d0/296d97e84_generated_a3db9b95.png"],styles:["Kit Completo","Pieza Única","Set de Papelería","Caja Curada"],occasions:["Cumpleaños","Aniversario","Baby Shower","San Valentín","Navidad"],includes:["Personalización total incluida","Caja de regalo premium","Tarjeta de mensaje manuscrita","Foto del producto antes de enviar"],deliveryDays:"5–8 días hábiles",minOrder:1}
      };

      const productId = new URLSearchParams(window.location.search).get('id') || 'toppers';
      const product = PRODUCTS_DATA[productId] || PRODUCTS_DATA.toppers;
      let selectedImage = 0, quantity = product.minOrder;
      let style = product.styles[0], occasion = product.occasions[0];

      document.querySelectorAll('[data-product-title]').forEach(el=>el.textContent=product.title);
      document.getElementById('pdTagline').textContent = product.tagline;
      document.getElementById('pdReviews').textContent = `${product.rating}.0 (${product.reviewCount} reseñas)`;
      document.getElementById('pdDelivery').textContent = product.deliveryDays;
      document.getElementById('pdMinOrder').textContent = product.minOrder>1?`(mínimo ${product.minOrder} piezas)`:'';
      document.getElementById('pdQtyValue').textContent = quantity;

      const tag = document.getElementById('pdTag');
      if(product.tag){ tag.textContent = `✦ ${product.tag}`; } else tag.style.display='none';

      const includes = document.getElementById('pdIncludes');
      includes.innerHTML = product.includes.map(i=>`<div class="pd-inc-item"><span class="pd-inc-icon"></span><span>${i}</span></div>`).join('');

      const renderButtons=(items,containerId,current,setter)=>{
        const c=document.getElementById(containerId); c.innerHTML='';
        items.forEach(v=>{const b=document.createElement('button'); b.textContent=v; b.className=v===current?`is-active ${containerId==='pdOccasions'?'is-occasion':'is-style'}`:''; b.onclick=()=>setter(v); c.appendChild(b);});
      };
      const refreshSelections=()=>{
        document.getElementById('pdStyleCurrent').textContent=style;
        document.getElementById('pdOccasionCurrent').textContent=occasion;
        renderButtons(product.styles,'pdStyles',style,v=>{style=v;refreshSelections();});
        renderButtons(product.occasions,'pdOccasions',occasion,v=>{occasion=v;refreshSelections();});
      };
      refreshSelections();

      document.getElementById('pdMinus').onclick=()=>{ quantity=Math.max(product.minOrder, quantity-(product.minOrder>1?5:1)); document.getElementById('pdQtyValue').textContent=quantity; };
      document.getElementById('pdPlus').onclick=()=>{ quantity += (product.minOrder>1?5:1); document.getElementById('pdQtyValue').textContent=quantity; };

      const main=document.getElementById('pdMainImage'), thumbs=document.getElementById('pdThumbs'), dots=document.getElementById('pdDots');
      const renderGallery=()=>{
        main.src=product.images[selectedImage]; main.alt=`${product.title} - vista ${selectedImage+1}`;
        thumbs.innerHTML=''; dots.innerHTML='';
        product.images.forEach((img,i)=>{
          const t=document.createElement('button'); t.className=i===selectedImage?'is-active':''; t.innerHTML=`<img src="${img}" alt="Vista ${i+1}">`; t.onclick=()=>{selectedImage=i;renderGallery();}; thumbs.appendChild(t);
          const d=document.createElement('button'); d.className=i===selectedImage?'is-active':''; d.onclick=()=>{selectedImage=i;renderGallery();}; dots.appendChild(d);
        });
      };
      document.getElementById('pdPrev').onclick=()=>{selectedImage=(selectedImage-1+product.images.length)%product.images.length;renderGallery();};
      document.getElementById('pdNext').onclick=()=>{selectedImage=(selectedImage+1)%product.images.length;renderGallery();};
      if(product.images.length<=1){ document.getElementById('pdPrev').style.display='none'; document.getElementById('pdNext').style.display='none'; }
      renderGallery();

      const like=document.getElementById('pdLike'); let liked=false; like.onclick=()=>{liked=!liked; like.classList.toggle('is-liked', liked);};
      const share=document.getElementById('pdShare');
      share.onclick=async()=>{
        const url=window.location.href;
        try {
          if (navigator.share) await navigator.share({title: product.title, url});
          else { await navigator.clipboard.writeText(url); share.classList.add('is-copied'); setTimeout(()=>share.classList.remove('is-copied'),1200); }
        } catch {}
      };

      const related = Object.values(PRODUCTS_DATA).filter(p=>p.id!==product.id).slice(0,3);
      document.getElementById('pdRelated').innerHTML = related.map((p,index)=>`
        <a href="/producto?id=${p.id}" class="pd-r-card pd-reveal pd-reveal--up" style="--d:${(index*0.1).toFixed(1)}s;--dur:.5s">
          <img src="${p.images[0]}" alt="${p.title}" />
          <div class="overlay"></div>
          ${p.tag?`<span class="tag">${p.tag}</span>`:''}
          <h3>${p.title}</h3>
        </a>`).join('');
      document.querySelectorAll('#pdRelated .pd-reveal').forEach((el)=>el.classList.add('is-visible'));



      const ioEls = document.querySelectorAll('.pd-reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        ioEls.forEach((el) => io.observe(el));
      } else {
        ioEls.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>

<style is:global>

  .pd-reveal{opacity:0;will-change:transform,opacity}
  .pd-reveal--up{transform:translateY(20px);--from-y:20px}
  .pd-reveal--left{transform:translateX(-20px);opacity:0;--from-x:-20px}
  .pd-reveal--right{transform:translateX(20px);--from-x:20px}
  .pd-reveal.is-visible{animation:pdIn var(--dur,.6s) ease-out var(--d,0s) forwards}
  @keyframes pdIn{0%{opacity:0;transform:translate(var(--from-x,0),var(--from-y,0))}100%{opacity:1;transform:translate(0,0)}}


  .wrap{max-width:1280px;margin:0 auto;padding:0 20px}
  @media(min-width:768px){.wrap{padding:0 32px}}
  .pd-main{padding-top:80px;background:hsl(var(--background));color:hsl(var(--foreground));font-family:'DM Sans',system-ui,sans-serif}
  .pd-breadcrumb{padding:28px 20px 16px}
  .pd-breadcrumb nav{display:flex;gap:8px;align-items:center;font-size:.875rem;color:hsl(var(--muted-foreground))}
  .pd-breadcrumb a{text-decoration:none;color:hsl(var(--muted-foreground))} .pd-breadcrumb a:hover{color:hsl(var(--foreground))}

  .pd-hero{padding-bottom:80px}
  .pd-grid{display:grid;gap:48px;align-items:start}
  .pd-gallery__main{position:relative;border-radius:24px;overflow:hidden;aspect-ratio:1/1;background:hsl(var(--muted))}
  .pd-gallery__paper{position:absolute;inset:-8px;border-radius:24px}
  .pd-gallery__paper--a{background:hsl(var(--secondary) / .3);transform:rotate(1deg)}
  .pd-gallery__paper--b{background:hsl(var(--primary) / .15);transform:rotate(-1deg)}
  #pdMainImage{position:relative;width:100%;height:100%;object-fit:cover;border-radius:18px;transition:opacity .25s ease}
  .pd-gallery__arrow{position:absolute;top:50%;transform:translateY(-50%);left:12px;width:40px;height:40px;border-radius:999px;border:1px solid hsl(var(--border) / .8);background:hsl(var(--card) / .9);backdrop-filter:blur(6px);cursor:pointer;opacity:0;transition:.2s}
  .pd-gallery__main:hover .pd-gallery__arrow{opacity:1}
  .pd-gallery__arrow.is-right{left:auto;right:12px}
  .pd-gallery__dots{position:absolute;left:50%;transform:translateX(-50%);bottom:14px;display:flex;gap:6px}
  .pd-gallery__dots button{width:6px;height:6px;border-radius:999px;border:0;background:hsl(var(--card) / .55);cursor:pointer}
  .pd-gallery__dots .is-active{width:20px;background:hsl(var(--card))}
  .pd-gallery__thumbs{margin-top:12px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .pd-gallery__thumbs button{border:2px solid transparent;border-radius:12px;padding:0;overflow:hidden;cursor:pointer;transition:.2s}
  .pd-gallery__thumbs button:hover{border-color:hsl(var(--border))}
  .pd-gallery__thumbs .is-active{border-color:var(--color-primary-dark);box-shadow:0 6px 16px hsl(var(--primary) / .25)}
  .pd-gallery__thumbs img{width:100%;aspect-ratio:1/1;object-fit:cover}

  .pd-info h1{font-family:'Playfair Display',Georgia,serif;font-size:1.875rem;line-height:1.25;margin:0;color:hsl(var(--foreground));font-weight:600}
  .pd-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
  .pd-tags{display:flex;gap:8px;flex-wrap:wrap}
  .pd-tag{padding:6px 10px;border-radius:999px;background:hsl(var(--accent) / .2);color:hsl(var(--accent-foreground));border:1px solid hsl(var(--accent) / .3);font-size:.75rem;font-weight:500}
  .pd-tag.is-hand{background:color-mix(in srgb, var(--color-primary) 14%, white);border-color:color-mix(in srgb, var(--color-primary) 28%, white);color:var(--color-primary-dark)}
  .pd-actions{display:flex;gap:8px;align-items:center}.pd-like{width:36px;height:36px;border-radius:999px;border:1px solid hsl(var(--border));background:hsl(var(--card));cursor:pointer;display:grid;place-items:center;color:hsl(var(--muted-foreground))}
  .pd-like svg{width:16px;height:16px;stroke:currentColor}
  .pd-like.is-liked{color:hsl(var(--destructive));border-color:hsl(var(--destructive) / .3);background:hsl(var(--card))5f5}
  .pd-like.is-liked svg{fill:currentColor}
  .pd-like.is-copied{color:var(--color-primary-dark);border-color:color-mix(in srgb, var(--color-primary) 42%, white)}
  .pd-tagline{margin:4px 0 0;color:hsl(var(--muted-foreground));font-size:1rem}
  .pd-rating{margin-top:12px;display:flex;gap:8px;align-items:center}
  .pd-rating span{color:hsl(var(--accent));letter-spacing:.5px}
  .pd-rating small{color:hsl(var(--muted-foreground));font-size:.875rem}
  .pd-divider{margin:24px 0;border-top:1px solid hsl(var(--border) / .6)}

  .pd-options{display:grid;gap:24px}
  .pd-options label{display:block;font-size:.875rem;font-weight:500;margin-bottom:12px;color:hsl(var(--foreground))}
  .pd-options label b{color:var(--color-primary-dark)}
  #pdOccasionCurrent{color:var(--color-primary-dark)}
  .pd-options small{font-weight:400;color:hsl(var(--muted-foreground))}
  .pd-chips{display:flex;flex-wrap:wrap;gap:8px}
  .pd-chips button{padding:8px 16px;border-radius:999px;border:1px solid hsl(var(--border));background:hsl(var(--card));color:hsl(var(--muted-foreground));cursor:pointer;transition:.2s;font-size:.875rem;font-weight:500}
  .pd-chips button:hover{border-color:color-mix(in srgb, var(--color-primary) 35%, white);color:hsl(var(--foreground))}
  .pd-chips .is-active{font-weight:600}
  .pd-chips .is-active.is-style{background:var(--color-primary);border-color:var(--color-primary);color:hsl(var(--card))}
  .pd-chips .is-active.is-occasion{background:hsl(var(--secondary));border-color:hsl(var(--border));color:hsl(var(--secondary-foreground))}

  .pd-qty{display:inline-flex;gap:12px;align-items:center;background:hsl(var(--muted) / .8);padding:4px;border-radius:999px}
  .pd-qty button{width:36px;height:36px;border-radius:999px;border:1px solid hsl(var(--border));background:hsl(var(--card));cursor:pointer;display:grid;place-items:center}
  .pd-qty b{width:40px;text-align:center;font-size:1.125rem;font-weight:600}

  .pd-includes{margin-top:24px;background:hsl(var(--muted) / .6);border-radius:16px;padding:16px;display:grid;gap:10px;font-size:.92rem;color:hsl(var(--foreground))}
  .pd-inc-item{display:flex;align-items:flex-start;gap:10px}
  .pd-inc-icon{width:20px;height:20px;border-radius:999px;background:color-mix(in srgb, var(--color-primary) 22%, white);color:var(--color-primary-dark);display:grid;place-items:center;font-size:.72rem;line-height:1;margin-top:1px;flex:0 0 20px}
  .pd-inc-icon::before{content:"✓";font-size:12px;font-weight:700;line-height:1}
  .pd-delivery{margin-top:16px;font-size:.875rem;color:hsl(var(--muted-foreground));display:flex;align-items:center;gap:12px}
  .pd-delivery b{color:hsl(var(--foreground))}

  .pd-cta{margin-top:24px;display:flex;gap:12px;flex-direction:column}
  .pd-cta a{text-decoration:none;border-radius:999px;padding:14px 18px;text-align:center;font-weight:500;transition:.2s;display:inline-flex;align-items:center;justify-content:center;gap:8px}
  .pd-cta .is-primary{background:var(--color-primary);color:hsl(var(--card))}
  .pd-cta .is-primary:hover{background:var(--color-primary-dark);box-shadow:0 14px 30px hsl(var(--primary) / .28)}
  .pd-cta .is-ghost{border:2px solid hsl(var(--border));color:hsl(var(--foreground))}
  .pd-cta .is-ghost:hover{background:hsl(var(--secondary) / .35)}
  .pd-trust{margin-top:16px;text-align:center;font-size:.75rem;color:hsl(var(--muted-foreground));display:flex;align-items:center;justify-content:center;gap:4px}
  .pd-trust svg{color:hsl(var(--accent))}

  .pd-features{background:color-mix(in srgb, var(--color-secondary-light) 45%, white);padding:64px 0}

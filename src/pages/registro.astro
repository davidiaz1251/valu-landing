---
import AuthLayout from '../layouts/AuthLayout.astro';

const dots = [
  { top: 12, left: 10, delay: '0s', duration: '3.2s' },
  { top: 24, left: 84, delay: '.4s', duration: '3.8s' },
  { top: 38, left: 18, delay: '.9s', duration: '3.4s' },
  { top: 58, left: 90, delay: '1.3s', duration: '4s' },
  { top: 72, left: 14, delay: '1.8s', duration: '3.6s' },
  { top: 82, left: 78, delay: '.6s', duration: '3.1s' },
  { top: 46, left: 64, delay: '1.5s', duration: '3.7s' },
  { top: 18, left: 56, delay: '2s', duration: '3.3s' },
];
---

<AuthLayout title="Registro | Valu Kraft" description="Crea tu cuenta para acceder a plantillas y recursos de Valu Kraft." noindex={true}>
  <section class="auth section section--sm">
    <div class="auth-dots" aria-hidden="true">
      {dots.map((dot) => (
        <span class="auth-dot" style={`--top:${dot.top}%;--left:${dot.left}%;--delay:${dot.delay};--duration:${dot.duration};`}></span>
      ))}
    </div>

    <div class="container auth__container">
      <article class="auth-card">
        <h1>Crear cuenta</h1>
        <p>Regístrate gratis para acceder al área de plantillas.</p>

        <div id="authAlert" class="auth-alert" hidden></div>

        <form id="registerForm" class="auth-form">
          <label>
            Nombre
            <input type="text" name="name" required autocomplete="name" />
          </label>

          <label>
            Correo electrónico
            <input type="email" name="email" required autocomplete="email" />
          </label>

          <label>
            Contraseña
            <input type="password" name="password" required minlength="6" autocomplete="new-password" />
          </label>

          <button class="btn btn--primary" type="submit">Crear cuenta</button>
        </form>

        <a class="auth-login" href="/login">¿Ya tienes cuenta? Inicia sesión</a>
      </article>
    </div>
  </section>


<script type="module" src="/scripts/registro.js"></script>

<style>
  .auth {
    position: relative;
    padding-top: calc(var(--space-24) + var(--space-8));
    padding-bottom: var(--space-16);
    overflow: hidden;
    background: transparent;
  }
  .auth::before,
  .auth::after {
    content: '';
    position: absolute;
    border-radius: 999px;
    filter: blur(54px);
    pointer-events: none;
    z-index: 0;
  }
  .auth::before {
    width: 320px;
    height: 320px;
    top: -120px;
    right: -80px;
    background: hsla(350,40%,90%,.45);
  }
  .auth::after {
    width: 280px;
    height: 280px;
    bottom: -100px;
    left: -70px;
    background: hsla(160,30%,85%,.35);
  }

  .auth-dots {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .auth-dot {
    position: absolute;
    top: var(--top);
    left: var(--left);
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: hsla(42,65%,65%,.58);
    animation: authDotVanish var(--duration, 3.5s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  .auth__container { display: flex; justify-content: center; position: relative; z-index: 1; }
  .auth-card {
    width: 100%;
    max-width: 500px;
    background: rgba(255,255,255,.86);
    border: 1px solid rgba(228,218,213,.8);
    border-radius: 24px;
    box-shadow: 0 20px 46px rgba(47,31,40,.08);
    backdrop-filter: blur(8px);
    padding: var(--space-8);
  }
  .auth-card h1 {
    font-family: 'Playfair Display', Georgia, serif;
    color: #2f1f28;
    margin-bottom: 8px;
  }
  .auth-card p { color: #6b5963; margin-bottom: 0; }

  .auth-form { display: grid; gap: var(--space-4); margin-top: var(--space-6); }
  .auth-form label { display: grid; gap: var(--space-2); font-weight: 600; color: #4f3d46; }
  .auth-form input {
    border: 1px solid #e5d9d3;
    border-radius: 12px;
    padding: 12px 14px;
    background: rgba(255,255,255,.9);
    color: #2f1f28;
    transition: border-color .2s ease, box-shadow .2s ease;
  }
  .auth-form input:focus {
    outline: none;
    border-color: hsl(160 30% 45%);
    box-shadow: 0 0 0 3px rgba(50,130,105,.13);
  }

  .auth-form .btn,
  .auth-google {
    border-radius: 999px;
    padding: 12px 18px;
    font-weight: 600;
  }
  .auth-form .btn.btn--primary {
    background: hsl(160 30% 45%);
    color: #fff;
    box-shadow: 0 12px 24px rgba(50,130,105,.18);
  }
  .auth-form .btn.btn--primary:hover { background: hsl(160 30% 42%); }

  .auth-google { width: 100%; margin-top: var(--space-3); }
  .auth-google.btn--secondary {
    border: 1px solid rgba(220,206,198,.95);
    background: #fff;
    color: #4f3d46;
  }

  .auth-links { display: flex; justify-content: space-between; margin-top: var(--space-5); font-size: var(--text-sm); gap: 12px; }
  .auth-login { display: inline-block; margin-top: var(--space-5); font-size: var(--text-sm); }
  .auth-links a, .auth-login { color: #5f4a54; font-weight: 500; }
  .auth-links a:hover, .auth-login:hover { color: hsl(160 30% 40%); }

  .auth-alert { margin-top: var(--space-4); padding: var(--space-3); border-radius: 12px; background: #fff3f3; color: #9a1c1c; border: 1px solid #f3c5c5; }
  .auth-success { margin-top: var(--space-4); padding: var(--space-3); border-radius: 12px; background: #f3fff4; color: #1f7a2e; border: 1px solid #bde8c4; }

  @keyframes authDotVanish {
    0% { opacity: 0; transform: translate3d(0, 8px, 0) scale(.72); }
    20% { opacity: .8; transform: translate3d(0, 0, 0) scale(1); }
    60% { opacity: .62; }
    100% { opacity: 0; transform: translate3d(0, -12px, 0) scale(.78); }
  }

  @media (prefers-reduced-motion: reduce) {
    .auth-dot { animation: none; opacity: .35; }
  }

  @media (max-width: 640px) {
    .auth-card { padding: var(--space-6); border-radius: 18px; }
    .auth-links { flex-direction: column; }
  }
</style>

</AuthLayout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro | Valu Kraft" description="Crea tu cuenta para acceder a plantillas y recursos de Valu Kraft.">
  <section class="auth section section--sm">
    <div class="container auth__container">
      <article class="auth-card">
        <h1>Crear cuenta</h1>
        <p>Regístrate gratis para acceder al área de plantillas.</p>

        <div id="authAlert" class="auth-alert" hidden></div>

        <form id="registerForm" class="auth-form">
          <label>
            Nombre
            <input type="text" name="name" required autocomplete="name" />
          </label>

          <label>
            Correo electrónico
            <input type="email" name="email" required autocomplete="email" />
          </label>

          <label>
            Contraseña
            <input type="password" name="password" required minlength="6" autocomplete="new-password" />
          </label>

          <button class="btn btn--primary" type="submit">Crear cuenta</button>
        </form>

        <a class="auth-login" href="/login">¿Ya tienes cuenta? Inicia sesión</a>
      </article>
    </div>
  </section>
</Layout>

<script type="module">
  import { hasSupabaseConfig } from '../lib/supabase';
  import { registerWithEmail } from '../lib/auth';

  const alertBox = document.getElementById('authAlert');
  const registerForm = document.getElementById('registerForm');

  const showError = (text) => {
    alertBox.textContent = text;
    alertBox.hidden = false;
  };

  if (!hasSupabaseConfig()) {
    showError('Falta configurar Supabase en variables de entorno.');
  }

  registerForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const formData = new FormData(registerForm);

    try {
      await registerWithEmail(
        String(formData.get('email')),
        String(formData.get('password')),
        String(formData.get('name')),
      );
      window.location.href = '/plantillas';
    } catch (error) {
      showError('No se pudo crear la cuenta. Verifica el correo y la contraseña.');
      console.error(error);
    }
  });
</script>

<style>
  .auth { padding-top: calc(var(--space-24) + var(--space-6)); }
  .auth__container { display: flex; justify-content: center; }
  .auth-card { width: 100%; max-width: 460px; background: #fff; border: 1px solid var(--color-gray-200); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); padding: var(--space-8); }
  .auth-form { display: grid; gap: var(--space-4); margin-top: var(--space-5); }
  .auth-form label { display: grid; gap: var(--space-2); font-weight: var(--font-medium); }
  .auth-form input { border: 1px solid var(--color-gray-300); border-radius: var(--radius-md); padding: var(--space-3); }
  .auth-login { display: inline-block; margin-top: var(--space-5); }
  .auth-alert { margin-top: var(--space-4); padding: var(--space-3); border-radius: var(--radius-md); background: #fff3f3; color: #9a1c1c; border: 1px solid #f3c5c5; }
</style>

---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    number: '01',
    title: 'Cuéntanos tu idea',
    description: 'Escríbenos por WhatsApp o formulario con tu idea, evento o proyecto. No importa si aún no tienes todo claro, te ayudamos a definirlo.',
    icon: '💭',
    tips: [
      'Describe el tipo de producto que necesitas',
      'Cuéntanos la ocasión o evento',
      'Comparte inspiración si tienes (fotos, colores, estilos)',
      'Indica la fecha aproximada que lo necesitas'
    ]
  },
  {
    number: '02',
    title: 'Diseñamos juntos',
    description: 'Creamos propuestas personalizadas adaptadas a tus gustos, colores y estilo. Trabajamos contigo hasta que el diseño sea perfecto.',
    icon: '🎨',
    tips: [
      'Te enviamos bocetos y propuestas',
      'Puedes pedir cambios hasta estar satisfecho/a',
      'Seleccionamos materiales y acabados',
      'Definimos todos los detalles finales'
    ]
  },
  {
    number: '03',
    title: 'Presupuesto y confirmación',
    description: 'Te enviamos un presupuesto detallado y sin compromiso. Una vez aprobado y confirmada la reserva, comenzamos la producción.',
    icon: '📋',
    tips: [
      'Presupuesto transparente y desglosado',
      'Reserva del 50% para iniciar',
      'Confirmación de fechas de entrega',
      'Contrato de encargo si lo deseas'
    ]
  },
  {
    number: '04',
    title: 'Producción artesanal',
    description: 'Elaboramos tu pedido con materiales de calidad, cuidando cada detalle y utilizando nuestras herramientas profesionales.',
    icon: '✨',
    tips: [
      'Control de calidad en cada paso',
      'Te mantenemos informado/a del progreso',
      'Fotos del proceso si lo deseas',
      'Cuidado artesanal en cada pieza'
    ]
  },
  {
    number: '05',
    title: 'Entrega perfecta',
    description: 'Entregamos tu pedido listo para brillar. Empaquetado con cuidado y listo para tu evento o para sorprender a esa persona especial.',
    icon: '🎁',
    tips: [
      'Entrega en punto acordado o envío',
      'Empaquetado protector y bonito',
      'Pago del 50% restante',
      'Satisfacción garantizada'
    ]
  }
];

const faqs = [
  {
    question: '¿Cuánto tiempo tardan los encargos?',
    answer: 'Depende del tipo de producto y la cantidad. Normalmente entre 5-15 días hábiles. Para eventos importantes, recomendamos contactar con al menos 3-4 semanas de antelación.'
  },
  {
    question: '¿Hay un mínimo de pedido?',
    answer: 'No hay mínimo obligatorio, aunque para algunos productos puede haber cantidades recomendadas para optimizar costes. Siempre te asesoramos sobre la mejor opción.'
  },
  {
    question: '¿Puedo ver el diseño antes de producir?',
    answer: '¡Por supuesto! Siempre enviamos bocetos o maquetas digitales para tu aprobación antes de comenzar la producción. No empezamos hasta que estés 100% satisfecho/a.'
  },
  {
    question: '¿Qué formas de pago aceptáis?',
    answer: 'Aceptamos Bizum, transferencia bancaria y PayPal. Normalmente pedimos un 50% de reserva para iniciar el trabajo y el resto a la entrega.'
  },
  {
    question: '¿Hacéis envíos?',
    answer: 'Sí, enviamos a toda España. El coste de envío se calcula según el peso y destino. También ofrecemos entrega en mano en nuestra zona.'
  },
  {
    question: '¿Qué pasa si no me gusta el resultado?',
    answer: 'Trabajamos contigo en cada paso para asegurar que el resultado sea perfecto. Si hay algún problema con la calidad, lo solucionamos sin coste adicional.'
  }
];
---

<Layout title="Encargos personalizados paso a paso | Valu Kraft" description="Conoce el proceso de encargos personalizados de Valu Kraft: idea, diseño, aprobación y entrega de productos únicos.">
  <!-- Hero Section -->
  <section class="order-hero section--lg">
    <div class="order-hero__bg">
      <div class="blob blob--primary order-hero__blob order-hero__blob--1"></div>
      <div class="blob blob--accent order-hero__blob order-hero__blob--2"></div>
    </div>
    
    <div class="container">
      <div class="order-hero__content">
        <span class="section__badge">Proceso de encargo</span>
        <h1>Tu idea, <span class="gradient-text">hecha realidad</span></h1>
        <p class="order-hero__description">
          Cada encargo es único y especial. Te acompañamos en cada paso del proceso 
          creativo para asegurar que el resultado supere tus expectativas.
        </p>
        <div class="order-hero__cta">
          <a href="https://wa.me/34600000000" class="btn btn--primary btn--lg" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Iniciar encargo por WhatsApp
          </a>
          <a href="/contacto" class="btn btn--secondary btn--lg">
            Formulario de contacto
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="process-full section">
    <div class="container">
      <div class="section__header text-center">
        <span class="section__badge">Paso a paso</span>
        <h2 class="section__title">Cómo funciona</h2>
        <p class="section__description">
          Un proceso sencillo, transparente y colaborativo. 
          Estamos contigo en cada momento.
        </p>
      </div>
      
      <div class="process-full__timeline">
        {steps.map((step, index) => (
          <div class={`step-card ${index % 2 === 1 ? 'step-card--right' : ''}`}>
            <div class="step-card__connector">
              <div class="step-card__dot"></div>
            </div>
            <div class="step-card__content">
              <div class="step-card__header">
                <span class="step-card__icon">{step.icon}</span>
                <div class="step-card__number">{step.number}</div>
              </div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
              <div class="step-card__tips">
                {step.tips.map((tip) => (
                  <div class="step-card__tip">
                    <span class="step-card__tip-icon">•</span>
                    <span>{tip}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Include Section -->
  <section class="info-section section">
    <div class="container">
      <div class="info-section__wrapper">
        <div class="info-card">
          <div class="info-card__icon">📝</div>
          <h3>Qué incluir en tu mensaje</h3>
          <ul>
            <li><span>✓</span> Tipo de producto que necesitas</li>
            <li><span>✓</span> Ocasión o evento (boda, cumpleaños, etc.)</li>
            <li><span>✓</span> Temática, colores o estilo preferido</li>
            <li><span>✓</span> Cantidad aproximada</li>
            <li><span>✓</span> Fecha límite de entrega</li>
            <li><span>✓</span> Presupuesto orientativo (opcional)</li>
          </ul>
        </div>
        
        <div class="info-card">
          <div class="info-card__icon">⚡</div>
          <h3>Respuesta rápida</h3>
          <p>
            Respondemos en menos de 24 horas (normalmente mucho antes). 
            Analizamos tu solicitud y te contactamos para conocer mejor 
            tu proyecto y darte una primera orientación.
          </p>
          <div class="info-card__badge">
            <span class="pulse-dot"></span>
            Respuesta en menos de 24h
          </div>
        </div>
        
        <div class="info-card">
          <div class="info-card__icon">💡</div>
          <h3>Sin compromiso</h3>
          <p>
            Puedes preguntarnos lo que quieras antes de decidir. 
            Te damos presupuesto gratuito y sin ningún tipo de compromiso. 
            Solo pagas si decides seguir adelante.
          </p>
          <div class="info-card__cta">
            <a href="https://wa.me/34600000000" class="btn btn--outline">Consultar sin compromiso</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="faqs section">
    <div class="container">
      <div class="section__header text-center">
        <span class="section__badge">Dudas frecuentes</span>
        <h2 class="section__title">Preguntas frecuentes</h2>
      </div>
      
      <div class="faqs__grid">
        {faqs.map((faq, index) => (
          <div class="faq-card" data-index={index}>
            <div class="faq-card__question" onclick={`this.parentElement.classList.toggle('faq-card--open')`}>
              <h4>{faq.question}</h4>
              <span class="faq-card__toggle">+</span>
            </div>
            <div class="faq-card__answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="order-cta section">
    <div class="container">
      <div class="order-cta__wrapper">
        <div class="order-cta__content">
          <h2>¿Listo/a para empezar?</h2>
          <p>
            Cuéntanos tu idea y la hacemos realidad. Estamos deseando 
            conocer tu proyecto y ayudarte a crear algo único.
          </p>
          <div class="order-cta__buttons">
            <a href="https://wa.me/34600000000" class="btn btn--primary btn--lg" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
            <a href="/contacto" class="btn btn--secondary btn--lg">
              Formulario
            </a>
          </div>
        </div>
        
        <div class="order-cta__visual">
          <div class="order-cta__emoji">✨</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Order Hero */
  .order-hero {
    position: relative;
    padding-top: calc(var(--space-24) + 60px);
    text-align: center;
    overflow: hidden;
  }
  
  .order-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }
  
  .order-hero__blob {
    position: absolute;
    width: 500px;
    height: 500px;
  }
  
  .order-hero__blob--1 {
    top: -200px;
    right: -100px;
    background: var(--color-primary-light);
    animation: float 8s ease-in-out infinite;
  }
  
  .order-hero__blob--2 {
    bottom: -200px;
    left: -200px;
    background: var(--color-accent);
    animation: float 10s ease-in-out infinite reverse;
  }
  
  .order-hero__content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .order-hero__content h1 {
    margin-bottom: var(--space-6);
  }
  
  .order-hero__description {
    font-size: var(--text-xl);
    color: var(--color-gray-600);
    margin-bottom: var(--space-8);
  }
  
  .order-hero__cta {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  
  /* Process Full */
  .process-full__timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }
  
  .process-full__timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--color-primary-light), var(--color-lavender), var(--color-secondary-light));
    border-radius: var(--radius-full);
    transform: translateX(-50%);
  }
  
  .step-card {
    position: relative;
    width: 50%;
    padding-right: var(--space-16);
    padding-bottom: var(--space-10);
  }
  
  .step-card--right {
    margin-left: 50%;
    padding-right: 0;
    padding-left: var(--space-16);
  }
  
  .step-card__connector {
    position: absolute;
    top: 0;
    right: -12px;
  }
  
  .step-card--right .step-card__connector {
    right: auto;
    left: -12px;
  }
  
  .step-card__dot {
    width: 24px;
    height: 24px;
    background: var(--color-white);
    border: 4px solid var(--color-primary);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-md);
  }
  
  .step-card__content {
    background: var(--color-white);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }
  
  .step-card:hover .step-card__content {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }
  
  .step-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  
  .step-card__icon {
    font-size: var(--text-3xl);
  }
  
  .step-card__number {
    padding: var(--space-1) var(--space-3);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-primary-dark);
  }
  
  .step-card__content h3 {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }
  
  .step-card__content > p {
    color: var(--color-gray-600);
    margin-bottom: var(--space-4);
  }
  
  .step-card__tips {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .step-card__tip {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  
  .step-card__tip-icon {
    color: var(--color-primary);
  }
  
  /* Info Section */
  .info-section {
    background: linear-gradient(180deg, var(--color-white) 0%, var(--color-cream) 100%);
  }
  
  .info-section__wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  
  .info-card {
    background: var(--color-white);
    padding: var(--space-8);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }
  
  .info-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }
  
  .info-card__icon {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }
  
  .info-card h3 {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }
  
  .info-card ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .info-card li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }
  
  .info-card li span:first-child {
    color: var(--color-primary);
  }
  
  .info-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  
  .info-card__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: var(--color-mint);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: #4A7A68;
  }
  
  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #4A7A68;
    border-radius: var(--radius-full);
    animation: pulse 2s ease-in-out infinite;
  }
  
  .info-card__cta {
    margin-top: var(--space-4);
  }
  
  /* FAQs */
  .faqs {
    background: var(--color-cream);
  }
  
  .faqs__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .faq-card {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }
  
  .faq-card:hover {
    box-shadow: var(--shadow-md);
  }
  
  .faq-card__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-5);
    cursor: pointer;
    transition: background var(--transition-fast);
  }
  
  .faq-card__question:hover {
    background: var(--color-gray-100);
  }
  
  .faq-card__question h4 {
    font-family: var(--font-primary);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin: 0;
    padding-right: var(--space-4);
  }
  
  .faq-card__toggle {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    color: var(--color-primary-dark);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    transition: transform var(--transition-base);
  }
  
  .faq-card--open .faq-card__toggle {
    transform: rotate(45deg);
  }
  
  .faq-card__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-base), padding var(--transition-base);
  }
  
  .faq-card--open .faq-card__answer {
    max-height: 200px;
  }
  
  .faq-card__answer p {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    margin: 0;
  }
  
  /* Order CTA */
  .order-cta__wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-12);
    align-items: center;
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-lavender));
    padding: var(--space-12);
    border-radius: var(--radius-2xl);
  }
  
  .order-cta__content h2 {
    margin-bottom: var(--space-4);
  }
  
  .order-cta__content p {
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    margin-bottom: var(--space-6);
  }
  
  .order-cta__buttons {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  
  .order-cta__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .order-cta__emoji {
    font-size: 120px;
    animation: float 4s ease-in-out infinite;
  }
  
  /* Responsive */
  @media (max-width: 992px) {
    .process-full__timeline::before {
      left: 12px;
    }
    
    .step-card,
    .step-card--right {
      width: 100%;
      margin-left: 0;
      padding-left: var(--space-12);
      padding-right: 0;
    }
    
    .step-card__connector,
    .step-card--right .step-card__connector {
      left: 0;
      right: auto;
    }
    
    .info-section__wrapper {
      grid-template-columns: 1fr;
    }
    
    .faqs__grid {

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Toppers personalizados para cumpleaños | Valu Kraft" description="Toppers personalizados para cumpleaños infantiles y adultos. Diseño con nombre, edad y temática. Envíos a toda España.">
  <section class="section section--lg">
    <div class="container page">
      <span class="section__badge">Cumpleaños</span>
      <h1>Toppers personalizados para cumpleaños</h1>
      <p class="lead">Creamos toppers personalizados para cumpleaños con estilos infantiles, elegantes y temáticos. Personaliza nombre, edad y colores.</p>
      <p><a href="/encargos" class="btn btn--primary">Quiero mi topper de cumpleaños</a></p>
    </div>
  </section>
</Layout>

<style>.page{max-width:820px}.lead{font-size:1.12rem;color:var(--color-gray-600)}</style>

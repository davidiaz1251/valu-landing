---
import Layout from '../layouts/Layout.astro';
import { templates } from '../data/templates';
---

<Layout
  title="Plantillas descargables | Valu Kraft"
  description="Descarga plantillas de diseño listas para personalizar en tus celebraciones."
>
  <section class="templates-hero section section--sm">
    <div class="container">
      <span class="section__badge">Recursos</span>
      <h1 class="templates-hero__title">Plantillas descargables</h1>
      <p class="templates-hero__description">Inicia sesión para descargar tus plantillas.</p>
      <div id="templatesSession" class="templates-session">Comprobando sesión...</div>
    </div>
  </section>

  <section class="templates section">
    <div class="container">
      {templates.length === 0 ? (
        <div class="templates-empty">
          <h2>Estamos preparando las primeras plantillas ✨</h2>
          <p>Muy pronto verás aquí descargas listas para tus celebraciones.</p>
        </div>
      ) : (
        <div class="templates__grid">
          {templates.map((item) => (
            <article
              class="template-card"
              data-template-id={item.id}
              data-storage-path={item.storagePath}
              data-required-roles={item.requiredRoles.join(',')}
            >
              <div class="template-card__meta">
                <span class="template-card__format">{item.format}</span>
              </div>
              <h2 class="template-card__title">{item.title}</h2>
              <p class="template-card__description">{item.description}</p>
              <p class="template-card__access" data-role-copy></p>
              <button class="btn btn--secondary template-card__cta" data-download-btn type="button" disabled>
                Descargar
              </button>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <script type="module" src="/scripts/plantillas.js"></script>

  <style>
    .templates-hero { padding-top: calc(var(--space-24) + var(--space-8)); padding-bottom: var(--space-8); text-align: center; }
    .templates-session { margin-top: var(--space-4); display: inline-block; padding: var(--space-2) var(--space-4); border-radius: var(--radius-full); background: #fff; border: 1px solid var(--color-gray-200); font-size: var(--text-sm); }
    .templates-hero__title { margin-top: var(--space-3); margin-bottom: var(--space-4); }
    .templates-hero__description { max-width: 700px; margin: 0 auto; font-size: var(--text-lg); }
    :global(.templates-empty) { max-width: 760px; margin: 0 auto; background: var(--color-white); border: 1px solid var(--color-gray-200); box-shadow: var(--shadow-md); border-radius: var(--radius-2xl); padding: var(--space-10); text-align: center; }
    :global(.templates__grid) { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    :global(.template-card) { 
      background: linear-gradient(180deg, #ffffff 0%, #fffdfc 100%);
      border: 1px solid #f0e3df;
      border-radius: 16px;
      padding: var(--space-6);
      box-shadow: 0 8px 22px rgba(53, 27, 35, 0.06);
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    :global(.template-card__media) { width:100%; aspect-ratio: 4 / 3; border-radius:12px; overflow:hidden; background:#f6f2f4; }
    :global(.template-card__media img){ width:100%; height:100%; object-fit:cover; display:block; }
    :global(.template-card:hover) {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(53, 27, 35, 0.1);
      border-color: #e8c7be;
    }
    :global(.template-card__meta) { display: flex; justify-content: flex-end; font-size: var(--text-sm); }
    :global(.template-card__format) { color: #7d6b72; font-size: 12px; letter-spacing: .04em; text-transform: uppercase; font-weight: 700; }
    :global(.template-card__title) { font-size: var(--text-2xl); margin: 0; }
    :global(.template-card__description), :global(.template-card__access) { margin: 0; color: #5f4d54; }
    :global(.template-card__access) { font-size: var(--text-sm); color: var(--color-gray-500); display:none; }
    :global(.template-card__cta) { margin-top: auto; align-self: flex-start; border-radius: 999px; padding: 10px 18px; }
    :global(.template-card__cta.is-disabled) { opacity: .6; cursor: not-allowed; }
    @media (max-width: 768px) { .templates-empty { padding: var(--space-6); } }
  </style>
</Layout>

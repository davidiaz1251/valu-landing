---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Mis plantillas | Valu Kraft"
  description="Tus plantillas personalizadas listas para descargar en Valu Kraft."
  noindex={true}
>
  <section class="tpl section section--sm">
    <div class="container tpl__container">
      <div class="tpl__head">
        <div class="tpl__pill">
          <span>✨</span>
          <span>Mis plantillas</span>
        </div>

        <h1 class="tpl__title">Tus plantillas personalizadas</h1>
        <p class="tpl__subtitle" id="templatesHeroCopy">
          Aquí encuentras todos los archivos disponibles para descargar.
        </p>

      </div>

      <div id="templatesLoader" class="tpl__loader" aria-live="polite">
        <span class="tpl__spinner" aria-hidden="true"></span>
      </div>

      <div id="templatesFilters" class="tpl__filters" hidden></div>

      <div id="templatesGrid" class="tpl__grid" hidden></div>

      <div id="templatesEmpty" class="tpl__empty" hidden></div>
    </div>
  </section>

  <script type="module" src="/scripts/plantillas.js?v=20260328c"></script>

  <style>
    .tpl {
      position: relative;
      font-family: 'DM Sans', system-ui, sans-serif;
      padding-top: calc(var(--space-24) + var(--space-6));
      padding-bottom: var(--space-16);
      background: transparent;
    }

    .tpl__container { max-width: 1280px; }

    .tpl__head { margin-bottom: var(--space-8); }

    .tpl__pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border-radius: 999px;
      background: hsl(var(--secondary) / .6);
      border: 1px solid hsl(var(--secondary) / .8);
      color: hsl(var(--secondary-foreground));
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .02em;
    }

    .tpl__title {
      margin: 14px 0 6px;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(1.875rem, 3.2vw, 2.25rem);
      line-height: 1.1;
      color: hsl(var(--foreground));
    }

    .tpl__subtitle {
      margin: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      color: hsl(var(--muted-foreground));
      max-width: 680px;
      font-size: 1.02rem;
      line-height: 1.65;
    }

    .tpl__loader {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 140px;
    }

        .tpl__loader[hidden],
    .tpl__filters[hidden],
    .tpl__grid[hidden],
    .tpl__empty[hidden] { display: none !important; }

    .tpl__spinner {
      width: 30px;
      height: 30px;
      border-radius: 999px;
      border: 3px solid hsl(var(--border));
      border-top-color: hsl(var(--primary));
      animation: tplSpin .9s linear infinite;
    }

    .tpl__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 2px 0 24px;
    }

    :global(.tpl-filter-btn) {
      border: 1px solid hsl(var(--border));
      background: hsl(var(--card));
      color: hsl(var(--secondary-foreground));
      border-radius: 999px;
      padding: 8px 14px;
      font-size: .86rem;
      font-weight: 600;
      cursor: pointer;
      transition: all .18s ease;
    }

    :global(.tpl-filter-btn:hover) { border-color: hsl(var(--ring)); }
    :global(.tpl-filter-btn.is-active) {
      background: hsl(var(--primary));
      border-color: hsl(var(--primary));
      color: hsl(var(--card));
    }

    .tpl__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    @media (min-width: 680px) {
      .tpl__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (min-width: 980px) {
      .tpl__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }

    @media (min-width: 1200px) {
      .tpl__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    }

    :global(.tpl-card) {
      background: linear-gradient(180deg, hsl(var(--card)) 0%, hsl(var(--card))dfc 100%);
      border: 1px solid hsl(var(--border));
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 8px 22px var(--shadow-sm);
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
      display: flex;
      flex-direction: column;
    }

    :global(.tpl-card:hover) {
      transform: translateY(-2px);
      box-shadow: 0 14px 28px var(--shadow-md);
      border-color: hsl(var(--border));
    }

    :global(.tpl-card__media) {
      position: relative;
      aspect-ratio: 4 / 3;
      background: hsl(var(--muted));
      display: grid;
      overflow: hidden;
      padding: 0;
    }

    :global(.tpl-card__media img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      transition: transform .45s ease;
      border-radius: 0;
      background: transparent;
      display: block;
    }

    :global(.tpl-card:hover .tpl-card__media img) { transform: scale(1.04); }

    :global(.tpl-card__file-icon) {
      font-size: 1.9rem;
      opacity: .55;
      color: hsl(var(--muted-foreground));
    }

    :global(.tpl-card__format) {
      position: absolute;
      top: 10px;
      right: 10px;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .04em;
      color: hsl(var(--secondary-foreground));
      border: 1px solid hsl(var(--border));
      border-radius: 999px;
      background: hsl(var(--card));
      padding: 4px 9px;
    }

    :global(.tpl-card__body) {
      padding: 16px 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 9px;
      min-height: 190px;
    }

    :global(.tpl-card__cat) {
      width: fit-content;
      border-radius: 999px;
      padding: 3px 9px;
      font-size: .72rem;
      font-weight: 700;
    }

    :global(.tpl-cat--toppers){ background: hsl(var(--accent) / .23); color: hsl(var(--accent-foreground)); }
    :global(.tpl-cat--invitaciones){ background: hsl(var(--secondary) / .8); color: hsl(var(--secondary-foreground)); }
    :global(.tpl-cat--cajas){ background: hsl(var(--primary) / .2); color: hsl(var(--primary)); }
    :global(.tpl-cat--regalos){ background: hsl(var(--primary) / .13); color: hsl(var(--primary)); }
    :global(.tpl-cat--default){ background: hsl(var(--muted)); color: hsl(var(--muted-foreground)); }

    :global(.tpl-card__title) {
      margin: 0;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.02rem;
      color: hsl(var(--foreground));
      line-height: 1.25;
    }

    :global(.tpl-card__desc) {
      margin: 0;
      color: hsl(var(--muted-foreground));
      font-size: .8rem;
      line-height: 1.5;
      min-height: 38px;
    }

    :global(.tpl-card__btn) {
      margin-top: auto;
      width: 100%;
      border: 0;
      border-radius: 999px;
      background: hsl(var(--primary));
      color: hsl(var(--card));
      font-weight: 600;
      padding: 10px 14px;
      font-size: .87rem;
      cursor: pointer;
      transition: background .18s ease, opacity .18s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    :global(.tpl-card__btn:hover) { background: hsl(var(--primary)); }
    :global(.tpl-card__btn:disabled) { opacity: .58; cursor: not-allowed; }

    :global(.tpl-btn__icon) { width: 14px; height: 14px; flex: 0 0 14px; }

    .tpl__empty {
      text-align: center;
      border: 1px solid #eadfdb;
      background: transparent;
      border-radius: 20px;
      padding: 46px 20px;
      max-width: 700px;
      margin: 0 auto;
      box-shadow: 0 10px 24px var(--shadow-sm);
    }

    .tpl__empty-icon {
      width: 62px;
      height: 62px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      margin: 0 auto 14px;
      background: #f4ece9;
      font-size: 1.45rem;
    }

    .tpl__empty h3 {
      margin: 0;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      color: hsl(var(--foreground));
    }

    .tpl__empty p { color: hsl(var(--muted-foreground)); margin: 8px auto 0; max-width: 420px; }

    .tpl__empty a {
      margin-top: 16px;
      display: inline-flex;
      text-decoration: none;
      border-radius: 999px;
      background: hsl(var(--primary));
      color: hsl(var(--card));
      font-weight: 600;
      padding: 10px 16px;
    }

    @keyframes tplSpin { to { transform: rotate(360deg); } }

    @media (max-width: 640px) {
      .tpl__title { font-size: 2rem; }
      .tpl__subtitle { font-size: .94rem; }
    }
  </style>
</Layout>

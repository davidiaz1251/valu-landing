---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Toppers personalizados para tartas | Valu Kraft" description="Diseñamos toppers personalizados para cumpleaños, bodas y eventos. Elige temática, nombre y colores en Valu Kraft.">
  <section class="section section--lg">
    <div class="container page">
      <span class="section__badge">Toppers personalizados</span>
      <h1>Toppers personalizados para tartas y eventos</h1>
      <p class="lead">Creamos toppers artesanales con nombre, edad, temática y colores a juego con tu celebración.</p>
      <h2>¿Qué puedes personalizar?</h2>
      <ul>
        <li>Nombre y edad</li>
        <li>Temática (anime, infantil, elegante, etc.)</li>
        <li>Colores y acabados</li>
        <li>Tamaño según tu tarta</li>
      </ul>
      <p><a href="/encargos" class="btn btn--primary">Solicitar topper personalizado</a></p>
    </div>
  </section>
</Layout>

<style>
  .page{max-width:820px}
  .lead{font-size:1.12rem;color:var(--color-gray-600)}
</style>
